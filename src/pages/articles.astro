---
import Layout from '../components/Layout.astro';
import CopySlot from '../components/CopySlot.astro';
import AdminNote from '../components/AdminNote.astro';
import { getStorefront, getArticles, FALLBACK_STOREFRONT } from '../lib/api';
import { formatDateBg } from '../lib/dates';
import { cfImage, cfSrcset } from '../lib/img';

const [sfRaw, articles] = await Promise.all([getStorefront(), getArticles()]);
const sf = sfRaw ?? FALLBACK_STOREFRONT;
const featured = articles[0] ?? null;
const rest = articles.slice(1);
---
<Layout title={`Статии · ${sf.name}`} storefront={sf} pageLabel="Статии">
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Статии</span></nav>
    </div>

    <section class="section--tight" data-copy-section="articles.head">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow"><CopySlot slot="articles.head.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="articles.head.title" copy={sf.copy} /></h2>
          <p><CopySlot slot="articles.head.text" copy={sf.copy} /></p>
        </div>

        {articles.length === 0 && (
          <AdminNote text="Все още няма публикувани статии." />
        )}

        {featured && (
          <a
            href={`/articles/${featured.slug}`}
            class="card art-featured"
          >
            {featured.coverImageUrl
              ? <img src={cfImage(featured.coverImageUrl, 1000)} srcset={cfSrcset(featured.coverImageUrl, [560, 1000])}
                     sizes="(max-width:760px) 100vw, 520px"
                     alt={featured.title} style="width:100%;height:100%;min-height:280px;object-fit:contain;background:var(--surface-2)" />
              : <div class="ph" style="min-height:280px;border-radius:0"></div>
            }
            <div style="padding:clamp(22px,3vw,40px);display:flex;flex-direction:column;justify-content:center">
              <span class="tag" style="align-self:flex-start">Препоръчано</span>
              <h3 style="font-size:clamp(24px,3vw,34px);margin:14px 0 12px">{featured.title}</h3>
              {featured.excerpt && <p class="muted">{featured.excerpt}</p>}
              {featured.publishedAt && (
                <div class="muted" style="font-size:13.5px;margin-top:16px">{formatDateBg(featured.publishedAt)}</div>
              )}
            </div>
          </a>
        )}

        {rest.length > 0 && (
          <div class="grid grid--3">
            {rest.map((a) => (
              <a href={`/articles/${a.slug}`} class="card" style="text-decoration:none">
                {a.coverImageUrl
                  ? <img src={cfImage(a.coverImageUrl, 800)} srcset={cfSrcset(a.coverImageUrl, [400, 800])}
                         sizes="(max-width:700px) 100vw, 320px"
                         alt={a.title} style="width:100%;aspect-ratio:16/10;object-fit:cover" />
                  : <div class="ph" style="aspect-ratio:16/10"></div>
                }
                <div style="padding:20px 20px 24px;display:flex;flex-direction:column;flex:1">
                  <h3 style="font-size:20px;margin:0 0 10px">{a.title}</h3>
                  {a.excerpt && <p class="muted" style="font-size:14.5px">{a.excerpt}</p>}
                  {a.publishedAt && (
                    <div class="muted" style="font-size:13px;margin-top:14px">{formatDateBg(a.publishedAt)}</div>
                  )}
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Featured article: side-by-side on desktop, stacked on phones (inline grid
     styles can't carry a media query, so the two-column layout used to crush the
     image + text below ~700px). */
  .art-featured {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    overflow: hidden;
    /* Breathing room from the page header above + the article grid below. */
    margin-top: clamp(22px, 4vw, 32px);
    margin-bottom: 26px;
    text-decoration: none;
  }
  @media (max-width: 760px) {
    .art-featured { grid-template-columns: 1fr; }
    /* On phones the image sits on top; let it size to its natural ratio instead
       of being letterboxed inside a forced 280px-tall contain box. */
    .art-featured img { height: auto !important; min-height: 0 !important; }
  }
</style>
