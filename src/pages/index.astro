---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';
import ProductCard from '../components/ProductCard.astro';
import FarmerCard from '../components/FarmerCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import MediaSlot from '../components/MediaSlot.astro';
import CopySlot from '../components/CopySlot.astro';
import { getCatalog } from '../lib/api';
import { categoriesFrom, featured, catIdOf } from '../lib/catalog';
import { imageOrigin, mapEmbedSrc } from '../lib/site';
import ProductOfWeek from '../components/ProductOfWeek.astro';

// One round trip via /bootstrap (falls back to the four parallel reads on an older
// backend). Seeds the per-resource memo so the rest of this render + a within-TTL
// navigation to /shop etc. reuse the same fetch.
const boot = await getCatalog();
const { storefront: sf, products, farmers, subcats } = {
  storefront: boot.storefront,
  products: boot.products,
  farmers: boot.farmers,
  subcats: boot.subcategories,
};

const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const seeded = products.length > 0;
// Configurable landing blocks (settings.landing). Falls back to the storefront's
// original hardcoded behavior on an older backend: all cats, 3 farmers, 4 latest.
const DEFAULT_LANDING = {
  categories: { show: true, mode: 'auto', count: 0, ids: [] },
  farmers: { show: true, mode: 'auto', count: 3, ids: [] },
  latest: { show: true, mode: 'auto', count: 4, ids: [] },
  reviews: { show: false, ids: [] },
};
const L = sf.landing ?? DEFAULT_LANDING;
// Manual mode → render exactly the picked ids in pick order (dropping any that no
// longer exist); auto mode → the original count-based behavior.
const pickByIds = <T extends { id: string }>(list: T[], ids: string[] = []): T[] => {
  const byId = new Map(list.map((x) => [x.id, x]));
  return ids.map((id) => byId.get(id)).filter((x): x is T => Boolean(x));
};
const catList =
  L.categories.mode === 'manual'
    ? pickByIds(cats, L.categories.ids)
    : L.categories.count > 0
      ? cats.slice(0, L.categories.count)
      : cats;
const farmerList =
  L.farmers.mode === 'manual'
    ? pickByIds(farmers, L.farmers.ids)
    : farmers.slice(0, L.farmers.count);
const feat =
  L.latest.mode === 'manual'
    ? pickByIds(products, L.latest.ids).filter((p) => p.isActive !== false)
    : featured(products, L.latest.count);
const homeReviews = boot.homeReviews ?? [];
// Per-product availability map: productId → remaining (defensive: field absent on older backends).
const availMap = new Map((boot.availability ?? []).map((w: { productId: string; remaining: number }) => [w.productId, w.remaining]));
// «Продукт на седмицата» — resolved by the backend bootstrap; look it up by id.
const potwInfo = boot?.productOfWeek ?? null;
const potw = potwInfo ? products.find((p) => p.id === potwInfo.id) ?? null : null;
const showFarmers = sf.multiFarmer;
const farmerCount = (id: string) => products.filter((p) => p.farmerId === id).length;
const farmerCats = (id: string) =>
  new Set(products.filter((p) => p.farmerId === id).map((p) => catIdOf(p, sf.multiSubcat))).size;
const shopCta = showFarmers ? { href: '/farmers', label: 'Виж фермерите' } : { href: '/shop', label: 'Разгледай магазина' };
// Warm a connection to the image host before the browser meets the first <img>.
const imgOrigin = imageOrigin(sf.media?.['home.hero']?.url, products[0]?.imageUrl, farmers[0]?.imageUrl);
---
<Layout title={`${sf.name} · Фермерски пазар Чайка, Варна`} storefront={sf} imageOrigin={imgOrigin}>
  <main>
    <!-- HERO -->
    <section class="hero section" data-copy-section="home.hero">
      <div class="wrap hero-grid">
        <div>
          <span class="eyebrow"><CopySlot slot="home.hero.eyebrow" copy={sf.copy} /></span>
          <h1 style="margin-top:14px"><CopySlot slot="home.hero.title" copy={sf.copy} /></h1>
          <p class="lead" style="margin-top:20px;max-width:46ch"><CopySlot slot="home.hero.lead" copy={sf.copy} /></p>
          <div class="cta-row">
            <a href={shopCta.href} class="btn btn--primary btn--lg">{shopCta.label}</a>
            <a href="/shop" class="btn btn--ghost btn--lg">Поръчай онлайн</a>
          </div>
          <div class="hero-stats">
            <div><div class="n"><CopySlot slot="home.hero.stat1.n" copy={sf.copy} /></div><div class="l"><CopySlot slot="home.hero.stat1.l" copy={sf.copy} /></div></div>
            <div><div class="n">{cats.length || 5}</div><div class="l"><CopySlot slot="home.hero.stat2.l" copy={sf.copy} /></div></div>
            <div><div class="n"><CopySlot slot="home.hero.stat3.n" copy={sf.copy} /></div><div class="l"><CopySlot slot="home.hero.stat3.l" copy={sf.copy} /></div></div>
          </div>
        </div>
        <div>
          <MediaSlot slot="home.hero" media={sf.media} priority />
        </div>
      </div>
    </section>

    <!-- PRODUCT OF THE WEEK · optional highlight (hidden here when shown as a top bar) -->
    {potw && sf.productOfWeekPlacement !== 'bar' && (
      <ProductOfWeek potw={potw} note={potwInfo?.note ?? null} />
    )}

    <!-- TWO WAYS TO SHOP -->
    <section class="section--tight" data-copy-section="home.twoways">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:32px">
          <span class="eyebrow"><CopySlot slot="home.twoways.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="home.twoways.title" copy={sf.copy} /></h2>
        </div>
        <div class="grid grid--2">
          <article class="card pillar">
            <MediaSlot slot="site.pillar_market" media={sf.media} />
            <div class="pillar__body">
              <span class="pillar__ic"><Icon name="basket" /></span>
              <h3><CopySlot slot="home.pillar_market.title" copy={sf.copy} /></h3>
              <p><CopySlot slot="home.pillar_market.text" copy={sf.copy} /></p>
              <ul class="pillar__facts">
                <li><span class="fic"><Icon name="pin" /></span> <CopySlot slot="home.pillar_market.fact1" copy={sf.copy} /></li>
                <li><span class="fic"><Icon name="clock" /></span> <CopySlot slot="home.pillar_market.fact2" copy={sf.copy} /></li>
              </ul>
              <a href="/orders" class="btn btn--soft">Как работи пазарът</a>
            </div>
          </article>
          <article class="card pillar">
            <MediaSlot slot="site.pillar_delivery" media={sf.media} />
            <div class="pillar__body">
              <span class="pillar__ic"><Icon name="truck" /></span>
              <h3><CopySlot slot="home.pillar_delivery.title" copy={sf.copy} /></h3>
              <p><CopySlot slot="home.pillar_delivery.text" copy={sf.copy} /></p>
              <ul class="pillar__facts">
                <li><span class="fic"><Icon name="truck" /></span> <CopySlot slot="home.pillar_delivery.fact1" copy={sf.copy} /></li>
                <li><span class="fic"><Icon name="leaf" /></span> <CopySlot slot="home.pillar_delivery.fact2" copy={sf.copy} /></li>
              </ul>
              <a href="/shop" class="btn btn--soft">Към магазина</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- CATEGORIES -->
    {L.categories.show && catList.length > 0 && (
    <section class="section" data-copy-section="home.categories">
      <div class="wrap">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:28px;flex-wrap:wrap">
          <div class="section-head" style="margin:0">
            <span class="eyebrow"><CopySlot slot="home.categories.eyebrow" copy={sf.copy} /></span>
            <h2 style="margin-top:8px"><CopySlot slot="home.categories.title" copy={sf.copy} /></h2>
          </div>
          <a href="/shop" class="btn btn--soft">Виж целия магазин</a>
        </div>
        <div class="grid cat-grid">
          {catList.map((c) => <CategoryCard category={c} />)}
        </div>
      </div>
    </section>
    )}

    <!-- FARMERS (multi-farmer mode only) -->
    {L.farmers.show && showFarmers && farmerList.length > 0 && (
      <section class="section" style="background:var(--surface-2)" data-copy-section="home.farmers">
        <div class="wrap">
          <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:24px;flex-wrap:wrap">
            <div class="section-head" style="margin:0">
              <span class="eyebrow"><CopySlot slot="home.farmers.eyebrow" copy={sf.copy} /></span>
              <h2 style="margin-top:8px"><CopySlot slot="home.farmers.title" copy={sf.copy} /></h2>
            </div>
            <a href="/farmers" class="btn btn--soft">Всички фермери</a>
          </div>
          <div class="grid grid--3">
            {farmerList.map((f) => (
              <FarmerCard farmer={f} productCount={farmerCount(f.id)} categoryCount={farmerCats(f.id)} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FEATURED PRODUCTS -->
    {L.latest.show && seeded && (
    <section class="section--tight" data-copy-section="home.latest">
      <div class="wrap">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:24px;flex-wrap:wrap">
          <div class="section-head" style="margin:0">
            <span class="eyebrow"><CopySlot slot="home.latest.eyebrow" copy={sf.copy} /></span>
            <h2 style="margin-top:8px"><CopySlot slot="home.latest.title" copy={sf.copy} /></h2>
          </div>
          <a href="/shop" class="btn btn--soft">Виж всички</a>
        </div>
        <div class="grid grid--4">
          {feat.map((p) => <ProductCard product={p} remaining={availMap.has(p.id) ? (availMap.get(p.id) ?? null) : null} />)}
        </div>
      </div>
    </section>
    )}

    <!-- CUSTOMER REVIEWS · farmer-picked -->
    {L.reviews.show && homeReviews.length > 0 && (
    <section class="section--tight" data-copy-section="home.reviews">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:32px">
          <span class="eyebrow"><CopySlot slot="home.reviews.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="home.reviews.title" copy={sf.copy} /></h2>
        </div>
        <div class="grid grid--3">
          {homeReviews.map((r) => (
            <article class="card review-card">
              <div class="stars">{[0, 1, 2, 3, 4].map((i) => (
                <span style={`opacity:${i < r.rating ? 1 : 0.25}`}><Icon name="star" /></span>
              ))}</div>
              <p>„{r.body}"</p>
              <div class="who">
                <div><b>{r.authorName}</b><span>{r.authorLocation || 'клиент'}</span></div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
    )}

    <!-- HOW IT WORKS -->
    <section class="section" data-copy-section="home.how">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:34px">
          <span class="eyebrow"><CopySlot slot="home.how.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="home.how.title" copy={sf.copy} /></h2>
          <p><CopySlot slot="home.how.text" copy={sf.copy} /></p>
        </div>
        <div class="grid grid--3">
          <div class="card value-card"><div class="ic"><Icon name="heart" /></div><h3><CopySlot slot="home.how.s1.title" copy={sf.copy} /></h3><p><CopySlot slot="home.how.s1.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="produce" /></div><h3><CopySlot slot="home.how.s2.title" copy={sf.copy} /></h3><p><CopySlot slot="home.how.s2.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="cart" /></div><h3><CopySlot slot="home.how.s3.title" copy={sf.copy} /></h3><p><CopySlot slot="home.how.s3.text" copy={sf.copy} /></p></div>
        </div>
      </div>
    </section>

    <!-- MARKET LOCATION -->
    <section class="section" style="background:var(--surface-2)" data-copy-section="home.location">
      <div class="wrap">
        <div class="market-block">
          <div>
            <span class="eyebrow"><CopySlot slot="home.location.eyebrow" copy={sf.copy} /></span>
            <h2 style="font-size:clamp(28px,4vw,42px);margin-top:10px"><CopySlot slot="home.location.title" copy={sf.copy} /></h2>
            <p class="lead" style="margin-top:14px;max-width:42ch"><CopySlot slot="home.location.lead" copy={sf.copy} /></p>
            <ul class="market-facts">
              <li><span class="fic"><Icon name="pin" /></span><div><b><CopySlot slot="home.location.fact1.title" copy={sf.copy} /></b><span><CopySlot slot="home.location.fact1.sub" copy={sf.copy} /></span></div></li>
              <li><span class="fic"><Icon name="clock" /></span><div><b><CopySlot slot="home.location.fact2.title" copy={sf.copy} /></b><span><CopySlot slot="home.location.fact2.sub" copy={sf.copy} /></span></div></li>
              <li><span class="fic"><Icon name="truck" /></span><div><b><CopySlot slot="home.location.fact3.title" copy={sf.copy} /></b><span><CopySlot slot="home.location.fact3.sub" copy={sf.copy} /></span></div></li>
            </ul>
            <div class="cta-row" style="margin-top:26px">
              <a href="/orders" class="btn btn--primary">Как да поръчам</a>
              <a href="/contact" class="btn btn--ghost">Свържи се с нас</a>
            </div>
          </div>
          <iframe
            class="contact-map"
            style="aspect-ratio:4/3;height:100%"
            src={mapEmbedSrc(sf)}
            title="Карта · кв. Чайка, Варна"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <section class="section--tight" data-copy-section="home.trust">
      <div class="wrap">
        <div class="grid grid--3">
          <div class="card value-card"><div class="ic"><Icon name="leaf" /></div><h3><CopySlot slot="home.trust.1.title" copy={sf.copy} /></h3><p><CopySlot slot="home.trust.1.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="basket" /></div><h3><CopySlot slot="home.trust.2.title" copy={sf.copy} /></h3><p><CopySlot slot="home.trust.2.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="heart" /></div><h3><CopySlot slot="home.trust.3.title" copy={sf.copy} /></h3><p><CopySlot slot="home.trust.3.text" copy={sf.copy} /></p></div>
        </div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section class="section--tight" data-copy-section="home.newsletter">
      <div class="wrap">
        <div class="newsletter">
          <div>
            <h2><CopySlot slot="home.newsletter.title" copy={sf.copy} /></h2>
            <p><CopySlot slot="home.newsletter.text" copy={sf.copy} /></p>
          </div>
          <form data-api-form="newsletter">
            <input type="email" name="email" placeholder="твоят имейл" required />
            <button class="btn btn--accent" type="submit">Абонирай се</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <script>
    import '../scripts/forms.ts';
  </script>
</Layout>
