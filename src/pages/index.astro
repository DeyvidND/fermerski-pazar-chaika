---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';
import ProductCard from '../components/ProductCard.astro';
import FarmerCard from '../components/FarmerCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import MediaSlot from '../components/MediaSlot.astro';
import CopySlot from '../components/CopySlot.astro';
import { getCatalog } from '../lib/api';
import { categoriesFrom, featured, catIdOf } from '../lib/catalog';
import { imageOrigin, mapEmbedSrc } from '../lib/site';
import ProductOfWeek from '../components/ProductOfWeek.astro';

// One round trip via /bootstrap (falls back to the four parallel reads on an older
// backend). Seeds the per-resource memo so the rest of this render + a within-TTL
// navigation to /shop etc. reuse the same fetch.
const boot = await getCatalog();
const { storefront: sf, products, farmers, subcats } = {
  storefront: boot.storefront,
  products: boot.products,
  farmers: boot.farmers,
  subcats: boot.subcategories,
};

const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const seeded = products.length > 0;
// Configurable landing blocks (settings.landing). Falls back to the storefront's
// original hardcoded behavior on an older backend: all cats, 3 farmers, 4 latest.
const DEFAULT_LANDING = {
  categories: { show: true, count: 0 },
  farmers: { show: true, count: 3 },
  latest: { show: true, count: 4 },
  reviews: { show: false, ids: [] },
};
const L = sf.landing ?? DEFAULT_LANDING;
const catList = L.categories.count > 0 ? cats.slice(0, L.categories.count) : cats;
const farmerList = farmers.slice(0, L.farmers.count);
const feat = featured(products, L.latest.count);
const homeReviews = boot.homeReviews ?? [];
// Per-product availability map: productId → remaining (defensive: field absent on older backends).
const availMap = new Map((boot.availability ?? []).map((w: { productId: string; remaining: number }) => [w.productId, w.remaining]));
// «Продукт на седмицата» — resolved by the backend bootstrap; look it up by id.
const potwInfo = boot?.productOfWeek ?? null;
const potw = potwInfo ? products.find((p) => p.id === potwInfo.id) ?? null : null;
const showFarmers = sf.multiFarmer;
const farmerCount = (id: string) => products.filter((p) => p.farmerId === id).length;
const farmerCats = (id: string) =>
  new Set(products.filter((p) => p.farmerId === id).map((p) => catIdOf(p, sf.multiSubcat))).size;
const shopCta = showFarmers ? { href: '/farmers', label: 'Виж фермерите' } : { href: '/shop', label: 'Разгледай магазина' };
// Warm a connection to the image host before the browser meets the first <img>.
const imgOrigin = imageOrigin(sf.media?.['home.hero']?.url, products[0]?.imageUrl, farmers[0]?.imageUrl);
---
<Layout title={`${sf.name} · Фермерски пазар Чайка, Варна`} storefront={sf} imageOrigin={imgOrigin}>
  <main>
    <!-- HERO -->
    <section class="hero section">
      <div class="wrap hero-grid">
        <div>
          <span class="eyebrow"><CopySlot slot="home.hero.eyebrow" copy={sf.copy} fallback="Фермерски пазар · кв. Чайка, Варна" /></span>
          <h1 style="margin-top:14px"><CopySlot slot="home.hero.title" copy={sf.copy} fallback="Свежа храна директно от фермерите" /></h1>
          <p class="lead" style="margin-top:20px;max-width:46ch"><CopySlot slot="home.hero.lead" copy={sf.copy} multiline fallback="Ела на живо всеки петък на Чайка или поръчай онлайн — плодове, мляко, мед, месо и домашни сладка с доставка до дома." /></p>
          <div class="cta-row">
            <a href={shopCta.href} class="btn btn--primary btn--lg">{shopCta.label}</a>
            <a href="/shop" class="btn btn--ghost btn--lg">Поръчай онлайн</a>
          </div>
          <div class="hero-stats">
            <div><div class="n">Петък</div><div class="l">пазар на живо · Чайка</div></div>
            <div><div class="n">{cats.length || 5}</div><div class="l">категории продукти</div></div>
            <div><div class="n">100% българско</div><div class="l">местно от региона</div></div>
          </div>
        </div>
        <div>
          <MediaSlot slot="home.hero" media={sf.media} ratio="4/5" rounded priority
            label="Hero снимка · щандове на пазара · 4:5" />
        </div>
      </div>
    </section>

    <!-- PRODUCT OF THE WEEK · optional highlight (hidden here when shown as a top bar) -->
    {potw && sf.productOfWeekPlacement !== 'bar' && (
      <ProductOfWeek potw={potw} note={potwInfo?.note ?? null} />
    )}

    <!-- TWO WAYS TO SHOP -->
    <section class="section--tight">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:32px">
          <span class="eyebrow"><CopySlot slot="home.twoways.eyebrow" copy={sf.copy} fallback="Два начина да пазаруваш" /></span>
          <h2 style="margin-top:8px"><CopySlot slot="home.twoways.title" copy={sf.copy} fallback="На пазара или онлайн — ти избираш" /></h2>
        </div>
        <div class="grid grid--2">
          <article class="card pillar">
            <MediaSlot slot="site.pillar_market" media={sf.media} ratio="16/10" label="Пазар на Чайка · щандове · 16:10" />
            <div class="pillar__body">
              <span class="pillar__ic"><Icon name="basket" /></span>
              <h3><CopySlot slot="home.pillar_market.title" copy={sf.copy} fallback="Пазар на място" /></h3>
              <p><CopySlot slot="home.pillar_market.text" copy={sf.copy} multiline fallback="Всеки петък фермерите се събират на Чайка. Опитай, разгледай и вземи директно от стопанина — без посредник." /></p>
              <ul class="pillar__facts">
                <li><span class="fic"><Icon name="pin" /></span> кв. Чайка, бул. „Ал. Стамболийски“ (пред „Фратели“)</li>
                <li><span class="fic"><Icon name="clock" /></span> Всеки петък · 11:00–18:00</li>
              </ul>
              <a href="/orders" class="btn btn--soft">Как работи пазарът</a>
            </div>
          </article>
          <article class="card pillar">
            <MediaSlot slot="site.pillar_delivery" media={sf.media} ratio="16/10" label="Доставка до дома · кашон · 16:10" />
            <div class="pillar__body">
              <span class="pillar__ic"><Icon name="truck" /></span>
              <h3><CopySlot slot="home.pillar_delivery.title" copy={sf.copy} fallback="Доставка до дома" /></h3>
              <p><CopySlot slot="home.pillar_delivery.text" copy={sf.copy} multiline fallback="Запази продукти от сайта и ги получи удобно вкъщи. Поръчай онлайн, а ние ги доставяме свежи в петък." /></p>
              <ul class="pillar__facts">
                <li><span class="fic"><Icon name="truck" /></span> Доставка в петък · между 11:00 и 20:00 ч.</li>
                <li><span class="fic"><Icon name="leaf" /></span> Свежо, директно от щанда до вратата ти</li>
              </ul>
              <a href="/shop" class="btn btn--soft">Към магазина</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- CATEGORIES -->
    {L.categories.show && catList.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:28px;flex-wrap:wrap">
          <div class="section-head" style="margin:0">
            <span class="eyebrow"><CopySlot slot="home.categories.eyebrow" copy={sf.copy} fallback="Пазарувай по категория" /></span>
            <h2 style="margin-top:8px"><CopySlot slot="home.categories.title" copy={sf.copy} fallback="Какво ще намериш" /></h2>
          </div>
          <a href="/shop" class="btn btn--soft">Виж целия магазин</a>
        </div>
        <div class="grid cat-grid">
          {catList.map((c) => <CategoryCard category={c} />)}
        </div>
      </div>
    </section>
    )}

    <!-- FARMERS (multi-farmer mode only) -->
    {L.farmers.show && showFarmers && farmerList.length > 0 && (
      <section class="section" style="background:var(--surface-2)">
        <div class="wrap">
          <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:24px;flex-wrap:wrap">
            <div class="section-head" style="margin:0">
              <span class="eyebrow"><CopySlot slot="home.farmers.eyebrow" copy={sf.copy} fallback="Хора зад щандовете" /></span>
              <h2 style="margin-top:8px"><CopySlot slot="home.farmers.title" copy={sf.copy} fallback="Запознай се с фермерите" /></h2>
            </div>
            <a href="/farmers" class="btn btn--soft">Всички фермери</a>
          </div>
          <div class="grid grid--3">
            {farmerList.map((f) => (
              <FarmerCard farmer={f} productCount={farmerCount(f.id)} categoryCount={farmerCats(f.id)} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FEATURED PRODUCTS -->
    {L.latest.show && seeded && (
    <section class="section--tight">
      <div class="wrap">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:24px;flex-wrap:wrap">
          <div class="section-head" style="margin:0">
            <span class="eyebrow"><CopySlot slot="home.latest.eyebrow" copy={sf.copy} fallback="Свежо този петък" /></span>
            <h2 style="margin-top:8px"><CopySlot slot="home.latest.title" copy={sf.copy} fallback="Най-актуални предложения" /></h2>
          </div>
          <a href="/shop" class="btn btn--soft">Виж всички</a>
        </div>
        <div class="grid grid--4">
          {feat.map((p) => <ProductCard product={p} remaining={availMap.has(p.id) ? (availMap.get(p.id) ?? null) : null} />)}
        </div>
      </div>
    </section>
    )}

    <!-- CUSTOMER REVIEWS · farmer-picked -->
    {L.reviews.show && homeReviews.length > 0 && (
    <section class="section--tight">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:32px">
          <span class="eyebrow"><CopySlot slot="home.reviews.eyebrow" copy={sf.copy} fallback="Отзиви" /></span>
          <h2 style="margin-top:8px"><CopySlot slot="home.reviews.title" copy={sf.copy} fallback="Какво казват клиентите" /></h2>
        </div>
        <div class="grid grid--3">
          {homeReviews.map((r) => (
            <article class="card review-card">
              <div class="stars">{[0, 1, 2, 3, 4].map((i) => (
                <span style={`opacity:${i < r.rating ? 1 : 0.25}`}><Icon name="star" /></span>
              ))}</div>
              <p>„{r.body}”</p>
              <div class="who">
                <div class="ph avatar"></div>
                <div><b>{r.authorName}</b><span>{r.authorLocation || 'клиент'}</span></div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
    )}

    <!-- HOW IT WORKS -->
    <section class="section">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:34px">
          <span class="eyebrow"><CopySlot slot="home.how.eyebrow" copy={sf.copy} fallback="Как е подреден магазинът" /></span>
          <h2 style="margin-top:8px"><CopySlot slot="home.how.title" copy={sf.copy} fallback="Фермер → категория → продукт" /></h2>
          <p><CopySlot slot="home.how.text" copy={sf.copy} multiline fallback="Всеки продукт идва от конкретен фермер и е подреден в категория. Така знаеш точно кой стопанин стои зад храната ти." /></p>
        </div>
        <div class="grid grid--3">
          <div class="card value-card"><div class="ic"><Icon name="heart" /></div><h3><CopySlot slot="home.how.s1.title" copy={sf.copy} fallback="1 · Избираш фермер" /></h3><p><CopySlot slot="home.how.s1.text" copy={sf.copy} multiline fallback="Всяко стопанство има профил със снимка, история и собствен асортимент." /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="produce" /></div><h3><CopySlot slot="home.how.s2.title" copy={sf.copy} fallback="2 · Разглеждаш категориите" /></h3><p><CopySlot slot="home.how.s2.text" copy={sf.copy} multiline fallback="Продуктите на фермера са групирани по категории — плодове, мляко, мед, месо, сладка." /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="cart" /></div><h3><CopySlot slot="home.how.s3.title" copy={sf.copy} fallback="3 · Поръчваш продукта" /></h3><p><CopySlot slot="home.how.s3.text" copy={sf.copy} multiline fallback="Добавяш в количката директно от категорията или запазваш за петъчния пазар." /></p></div>
        </div>
      </div>
    </section>

    <!-- MARKET LOCATION -->
    <section class="section" style="background:var(--surface-2)">
      <div class="wrap">
        <div class="market-block">
          <div>
            <span class=”eyebrow”><CopySlot slot=”home.location.eyebrow” copy={sf.copy} fallback=”Локация” /></span>
            <h2 style=”font-size:clamp(28px,4vw,42px);margin-top:10px”><CopySlot slot=”home.location.title” copy={sf.copy} fallback=”Фермерски пазар — Чайка” /></h2>
            <p class=”lead” style=”margin-top:14px;max-width:42ch”><CopySlot slot=”home.location.lead” copy={sf.copy} multiline fallback=”Намираш ни в кв. Чайка, Варна — на бул. „Ал. Стамболийски”, точно пред „Фратели”.” /></p>
            <ul class="market-facts">
              <li><span class="fic"><Icon name="pin" /></span><div><b>кв. Чайка, бул. „Ал. Стамболийски“</b><span>пред „Фратели“, гр. Варна</span></div></li>
              <li><span class="fic"><Icon name="clock" /></span><div><b>Всеки петък · 11:00–18:00</b><span>пазар на живо с фермерите</span></div></li>
              <li><span class="fic"><Icon name="truck" /></span><div><b>Доставка в петък · 11:00–20:00 ч.</b><span>за онлайн поръчки до адрес</span></div></li>
            </ul>
            <div class="cta-row" style="margin-top:26px">
              <a href="/orders" class="btn btn--primary">Как да поръчам</a>
              <a href="/contact" class="btn btn--ghost">Свържи се с нас</a>
            </div>
          </div>
          <iframe
            class="contact-map"
            style="aspect-ratio:4/3;height:100%"
            src={mapEmbedSrc(sf)}
            title="Карта · кв. Чайка, Варна"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <section class="section--tight">
      <div class="wrap">
        <div class="grid grid--3">
          <div class="card value-card"><div class="ic"><Icon name="leaf" /></div><h3><CopySlot slot="home.trust.1.title" copy={sf.copy} fallback="Местно и сезонно" /></h3><p><CopySlot slot="home.trust.1.text" copy={sf.copy} multiline fallback="Всичко идва от ферми в региона на Варна — толкова свежо, колкото изобщо е възможно." /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="basket" /></div><h3><CopySlot slot="home.trust.2.title" copy={sf.copy} fallback="Директно от фермера" /></h3><p><CopySlot slot="home.trust.2.text" copy={sf.copy} multiline fallback="Без вериги и без посредник. Парите отиват при стопанина, който е отгледал продукта." /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="heart" /></div><h3><CopySlot slot="home.trust.3.title" copy={sf.copy} fallback="Познаваме си хората" /></h3><p><CopySlot slot="home.trust.3.text" copy={sf.copy} multiline fallback="Малка общност от стопани и клиенти, които се срещат всеки петък на Чайка." /></p></div>
        </div>
      </div>
    </section>

    <!-- NEWSLETTER -->
    <section class="section--tight">
      <div class="wrap">
        <div class="newsletter">
          <div>
            <h2><CopySlot slot="home.newsletter.title" copy={sf.copy} fallback="Какво има на пазара тази седмица?" /></h2>
            <p><CopySlot slot="home.newsletter.text" copy={sf.copy} multiline fallback="Абонирай се и получавай в четвъртък какво носят фермерите в петък. Без спам." /></p>
          </div>
          <form data-api-form="newsletter">
            <input type="email" name="email" placeholder="твоят имейл" required />
            <button class="btn btn--accent" type="submit">Абонирай се</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <script>
    import '../scripts/forms.ts';
  </script>
</Layout>
