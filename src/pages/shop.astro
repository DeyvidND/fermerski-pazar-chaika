---
import Layout from '../components/Layout.astro';
import CopySlot from '../components/CopySlot.astro';
import ProductCard from '../components/ProductCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCatalog } from '../lib/api';
import { categoriesFrom, catIdOf } from '../lib/catalog';
import { ICONS } from '../lib/icons';
import { ONLY_LOCAL_DELIVERY } from '../lib/config';
import { itemListLd } from '../lib/jsonld';
import { farmerSlugMap } from '../lib/farmer-slug';

const boot = await getCatalog();
const { storefront: sf, products, farmers, subcategories: subcats } = boot;
const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const active = products.filter((p) => p.isActive !== false);
const seeded = active.length > 0;
// „Най-продавани" chip — gated on the toggle. Membership = ONLY the real
// sales-ranked ids from the bootstrap (∩ the active catalog). No padding with
// featured/newest, so the chip reflects genuine best-sellers (or stays hidden
// on a shop with no sales yet). The chip filters by this set.
const bestSellersOn = sf.merchandising?.bestSellers?.show ?? false;
const activeIds = new Set(active.map((p) => p.id));
const bestSellerSet = new Set((boot.bestSellerIds ?? []).filter((id) => activeIds.has(id)));
const showBestChip = bestSellersOn && bestSellerSet.size > 0;
// Collision-safe slug per farmer (see lib/farmer-slug.ts).
const slugs = farmerSlugMap(farmers);
const farmerName = (id: string | null) => farmers.find((f) => f.id === id)?.name ?? null;
const farmerImg = (id: string | null) => {
  const f = farmers.find((x) => x.id === id);
  return f?.images?.[0] ?? f?.imageUrl ?? null;
};
// Gated on ONLY_LOCAL_DELIVERY (../lib/config) — courier is checkout-locked
// storefront-wide right now, so no badge/chip may promise it either.
const farmerCourierReady = (id: string | null) =>
  !ONLY_LOCAL_DELIVERY && (farmers.find((f) => f.id === id)?.courierReady ?? false);
// Show the courier chip only if at least one active product can ship by courier.
const showCourierChip = active.some((p) => farmerCourierReady(p.farmerId) && !(p.courierDisabled ?? false));
// Per-product availability map: productId → remaining (defensive: field absent on older backends).
const availMap = new Map((boot.availability ?? []).map((w: { productId: string; remaining: number }) => [w.productId, w.remaining]));
// Farmer filter — a compact <select> (not another chip row) so 10-40 farmers stay
// elder-friendly. Gated on multiFarmer + >1 farmer total; options are only the
// farmers who actually have an active product right now (an empty pick is useless).
const activeFarmerIds = new Set(active.map((p) => p.farmerId).filter((id): id is string => !!id));
const filterableFarmers = farmers.filter((f) => activeFarmerIds.has(f.id));
const showFarmerFilter = sf.multiFarmer && filterableFarmers.length > 1;
// Live per-category count over the ACTIVE set, keyed the same way the cards are
// (catIdOf). Drives the chip count badges and drops empty categories from the
// filter row (an empty-category filter is useless — same logic as the farmer
// filter). NB: cat.count from categoriesFrom() also counts INACTIVE, so we don't
// use it here.
const catCount = new Map<string, number>();
for (const p of active) {
  const k = catIdOf(p, sf.multiSubcat);
  if (k) catCount.set(k, (catCount.get(k) ?? 0) + 1);
}
const shopCats = cats.filter((c) => (catCount.get(c.id) ?? 0) > 0);
const courierCount = active.filter((p) => farmerCourierReady(p.farmerId) && !(p.courierDisabled ?? false)).length;
// „Зареди още" page size — SSR seeds the result bar with the first page's count.
const PAGE = 24;
const initialShown = Math.min(PAGE, active.length);
// SEO: ItemList of the active catalog (products without a slug have no public
// URL, so they're excluded — capped at 50 inside itemListLd). Omitted entirely
// on a not-yet-seeded shop rather than emitting an empty list.
const shopMetaDesc = `Онлайн магазин с плодове, зеленчуци, мляко, мед и месо от местните фермери на ${sf.name} — с доставка и вземане от място.`;
const shopListItems = active.filter((p) => p.slug).map((p) => ({ name: p.name, path: `/product/${p.slug}` }));
const structuredData = shopListItems.length ? itemListLd(shopListItems) : undefined;
---
<Layout title={`Магазин · ${sf.name}`} description={shopMetaDesc} storefront={sf} jsonLd={structuredData} pageLabel="Магазин">
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Магазин</span></nav>
    </div>

    <section class="section--tight" data-copy-section="shop.head">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow"><CopySlot slot="shop.head.eyebrow" copy={sf.copy} /></span>
          <h1 style="margin-top:8px"><CopySlot slot="shop.head.title" copy={sf.copy} /></h1>
          <p><CopySlot slot="shop.head.text" copy={sf.copy} /></p>
        </div>

        {seeded && (
          <div class="shop-search">
            <SearchBar id="shopSearch" placeholder="Търси продукт или фермер…" />
          </div>
        )}

        {(shopCats.length > 0 || showBestChip) && (
          <div class="chips-sticky">
            <div class="chips-row" id="catChips" role="group" aria-label="Категории">
              <button class="chip is-active" data-tab="all" aria-pressed="true">
                <span class="chip__ic" set:html={ICONS.basket} />
                <span class="chip__label">Всички</span>
                <span class="chip__count">{active.length}</span>
              </button>
              {showBestChip && (
                <button class="chip" data-tab="best-sellers" aria-pressed="false">
                  <span class="chip__ic" set:html={ICONS.star} />
                  <span class="chip__label">Най-продавани</span>
                  <span class="chip__count">{bestSellerSet.size}</span>
                </button>
              )}
              {shopCats.map((c) => (
                <button class="chip" data-tab={c.id} aria-pressed="false">
                  <span class="chip__ic" set:html={ICONS[c.icon] ?? ICONS.berry} />
                  <span class="chip__label">{c.name}</span>
                  <span class="chip__count">{catCount.get(c.id) ?? 0}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        {(showFarmerFilter || showCourierChip) && (
          <div class="shop-filters2">
            {showFarmerFilter && (
              <div class="field shop-farmer">
                <label for="farmerFilter">Филтър по фермер</label>
                <select id="farmerFilter" class="input">
                  <option value="all">Всички фермери</option>
                  {filterableFarmers.map((f) => <option value={f.id}>{f.name}</option>)}
                </select>
              </div>
            )}
            {showCourierChip && (
              <button class="chip chip--courier" id="courierChip" data-courier-filter aria-pressed="false">
                <span class="chip__ic" set:html={ICONS.truck} />
                <span class="chip__label">С куриер</span>
                <span class="chip__count">{courierCount}</span>
              </button>
            )}
          </div>
        )}

        {seeded && (
          <div class="shop-resultbar">
            <p class="result-count" id="shopCount">Показани {initialShown} от {active.length}</p>
            <button type="button" class="shop-reset" id="shopReset" hidden>Изчисти филтрите</button>
          </div>
        )}

        <div class="grid grid--4" id="catalogGrid" data-page-size={PAGE}>
          {seeded
            ? active.map((p) => (
                <ProductCard product={p} stepper farmerName={farmerName(p.farmerId)}
                  farmerCourierReady={farmerCourierReady(p.farmerId)}
                  farmerId={p.farmerId} farmerSlug={p.farmerId ? slugs.get(p.farmerId) : null}
                  farmerImage={farmerImg(p.farmerId)}
                  cat={catIdOf(p, sf.multiSubcat)}
                  remaining={availMap.has(p.id) ? (availMap.get(p.id) ?? null) : null}
                  bestSeller={bestSellerSet.has(p.id)} />
              ))
            : <p style="grid-column:1/-1;text-align:center;color:var(--muted);padding:48px 0">Все още няма продукти.</p>}
        </div>
        {seeded && (
          <p id="shopEmpty" style="text-align:center;color:var(--muted);padding:40px 0" hidden></p>
        )}
        {seeded && (
          <div class="shop-more" id="shopMore" hidden>
            <button type="button" class="btn btn--soft shop-more__btn" id="shopMoreBtn">
              Зареди още<span id="shopMoreCount" class="shop-more__count"></span>
            </button>
          </div>
        )}
      </div>
    </section>
  </main>
  <script>
    // Unified catalog filter: category chip + „С куриер" + text search all
    // compose (AND) through one apply(); a „Зареди още" pager then slices the
    // matched set. Filters and paging both write `display` but never conflict —
    // apply() decides membership, renderPage() decides how many of it are shown.
    import { wireSearch } from '../scripts/search';

    const stickyRow = document.querySelector<HTMLElement>('.chips-sticky');
    const chips = document.getElementById('catChips');
    const grid = document.getElementById('catalogGrid');
    const countEl = document.getElementById('shopCount');
    const emptyEl = document.getElementById('shopEmpty');
    const resetBtn = document.getElementById('shopReset');
    const moreWrap = document.getElementById('shopMore');
    const moreBtn = document.getElementById('shopMoreBtn');
    const moreCount = document.getElementById('shopMoreCount');
    const cards = grid ? Array.from(grid.querySelectorAll<HTMLElement>('[data-product]')) : [];
    const PAGE = Number(grid?.dataset.pageSize) || 24;

    // Sticky chip row parks just below the sticky header. The header wraps on some
    // in-app browsers, so its height isn't constant — measure it into a CSS var
    // rather than hardcoding an offset, and flag `.is-stuck` for the shadow.
    let stickyTop = 0;
    function syncStickyTop() {
      const header = document.querySelector<HTMLElement>('.site-header');
      stickyTop = header ? Math.round(header.getBoundingClientRect().height) : 0;
      document.documentElement.style.setProperty('--shop-sticky-top', stickyTop + 'px');
    }
    function syncStuck() {
      if (!stickyRow) return;
      stickyRow.classList.toggle('is-stuck', stickyRow.getBoundingClientRect().top <= stickyTop + 0.5);
    }
    syncStickyTop();
    syncStuck();
    window.addEventListener('resize', () => { syncStickyTop(); syncStuck(); });
    window.addEventListener('scroll', syncStuck, { passive: true });

    // Fade the right edge of the mobile chip scroller while there's more to
    // reveal, so the horizontal scroll is discoverable.
    function updateChipFade() {
      if (!chips) return;
      chips.classList.toggle(
        'chips-row--more',
        chips.scrollLeft + chips.clientWidth < chips.scrollWidth - 2,
      );
    }
    chips?.addEventListener('scroll', updateChipFade, { passive: true });
    window.addEventListener('resize', updateChipFade);
    updateChipFade();

    const state = { cat: 'all', courierOnly: false, q: '', farmer: 'all' };
    let matched: HTMLElement[] = []; // cards passing every active filter, in DOM order
    let shown = PAGE;                // how many of `matched` are currently visible

    // Show only the first `shown` of the matched set; hide the tail. Keeps the
    // result-bar count and the „Зареди още" button in sync.
    function renderPage() {
      const visible = Math.min(shown, matched.length);
      for (let i = 0; i < matched.length; i++) {
        matched[i].style.display = i < visible ? '' : 'none';
      }
      if (countEl) {
        countEl.textContent = matched.length === 0
          ? 'Няма резултати'
          : `Показани ${visible} от ${matched.length}`;
      }
      const remaining = matched.length - visible;
      if (moreWrap) moreWrap.hidden = remaining <= 0;
      if (moreCount) moreCount.textContent = remaining > 0 ? ` (още ${remaining})` : '';
    }

    function apply() {
      matched = [];
      for (const card of cards) {
        const matchCat =
          state.cat === 'all' ||
          card.dataset.cat === state.cat ||
          (state.cat === 'best-sellers' && card.dataset.bestseller === '1');
        const matchCourier = !state.courierOnly || card.dataset.courier === '1';
        const matchText = state.q === '' || (card.dataset.name || '').includes(state.q);
        const matchFarmer = state.farmer === 'all' || card.dataset.farmer === state.farmer;
        if (matchCat && matchCourier && matchText && matchFarmer) matched.push(card);
        else card.style.display = 'none';
      }
      shown = PAGE; // every filter change resets paging to the first page
      renderPage();

      const filtering = state.q !== '' || state.cat !== 'all' || state.courierOnly || state.farmer !== 'all';
      if (resetBtn) resetBtn.hidden = !filtering;
      if (emptyEl) {
        emptyEl.hidden = matched.length !== 0;
        emptyEl.textContent = state.q
          ? `Няма намерени продукти за „${state.q}“`
          : 'Няма продукти за този филтър';
      }
    }

    // „Зареди още" — reveal the next page. Auto-loads too when the button nears
    // the viewport (IntersectionObserver); the button stays as the manual/no-JS
    // fallback and the primary control.
    moreBtn?.addEventListener('click', () => { shown += PAGE; renderPage(); });
    if (moreWrap && 'IntersectionObserver' in window) {
      new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && !moreWrap.hidden && shown < matched.length) {
            shown += PAGE;
            renderPage();
          }
        }
      }, { rootMargin: '400px 0px' }).observe(moreWrap);
    }

    // Category chips (delegated). Courier chip has no data-tab, so it's ignored here.
    chips?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>('[data-tab]');
      if (!chip) return;
      chips.querySelectorAll<HTMLElement>('[data-tab]').forEach((c) => {
        c.classList.toggle('is-active', c === chip);
        c.setAttribute('aria-pressed', String(c === chip));
      });
      state.cat = chip.dataset.tab || 'all';
      apply();
    });

    // „С куриер" chip — independent toggle, composes with category + text.
    const courierChip = document.getElementById('courierChip');
    courierChip?.addEventListener('click', () => {
      state.courierOnly = !state.courierOnly;
      courierChip.classList.toggle('is-active', state.courierOnly);
      courierChip.setAttribute('aria-pressed', String(state.courierOnly));
      apply();
    });

    // Text search.
    wireSearch('shopSearch', (q) => {
      state.q = q;
      apply();
    });

    // Farmer filter — compact <select>, composes with category + courier + text.
    const farmerFilter = document.getElementById('farmerFilter') as HTMLSelectElement | null;
    farmerFilter?.addEventListener('change', () => {
      state.farmer = farmerFilter.value || 'all';
      apply();
    });

    // Reset every active filter back to default (all categories, no farmer, no
    // courier, empty search). Shown only while something is filtering.
    resetBtn?.addEventListener('click', () => {
      state.cat = 'all';
      state.courierOnly = false;
      state.farmer = 'all';
      chips?.querySelectorAll<HTMLElement>('[data-tab]').forEach((c) => {
        const isAll = c.dataset.tab === 'all';
        c.classList.toggle('is-active', isAll);
        c.setAttribute('aria-pressed', String(isAll));
      });
      if (courierChip) {
        courierChip.classList.remove('is-active');
        courierChip.setAttribute('aria-pressed', 'false');
      }
      if (farmerFilter) farmerFilter.value = 'all';
      const input = document.getElementById('shopSearch') as HTMLInputElement | null;
      if (input) {
        input.value = '';
        input.dispatchEvent(new Event('input', { bubbles: true }));
      }
      apply();
    });

    // Initial paint: SSR renders every card, so slice down to the first page.
    apply();

    // Deep link: /shop#<categoryId> activates that category chip on load
    // (its click re-runs apply() with that category).
    const hash = decodeURIComponent(location.hash.replace('#', ''));
    if (hash) {
      const chip = chips?.querySelector<HTMLElement>(`[data-tab="${CSS.escape(hash)}"]`);
      chip?.click();
    }
  </script>
</Layout>
