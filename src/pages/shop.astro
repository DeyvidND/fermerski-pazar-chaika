---
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getBootstrap, getStorefront, getProducts, getFarmers, getSubcategories, FALLBACK_STOREFRONT } from '../lib/api';
import { categoriesFrom, catIdOf } from '../lib/catalog';
import { money } from '../lib/money';

const boot = await getBootstrap();
const [sfRaw, products, farmers, subcats] = boot
  ? [boot.storefront, boot.products, boot.farmers, boot.subcategories]
  : await Promise.all([getStorefront(), getProducts(), getFarmers(), getSubcategories()]);
const sf = sfRaw ?? FALLBACK_STOREFRONT;
const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const active = products.filter((p) => p.isActive !== false);
const seeded = active.length > 0;
const farmerName = (id: string | null) => farmers.find((f) => f.id === id)?.name ?? null;
// «Продукт на седмицата» — resolved by the backend bootstrap; look it up by id.
const potwInfo = boot?.productOfWeek ?? null;
const potw = potwInfo ? products.find((p) => p.id === potwInfo.id) ?? null : null;
const potwHref = potw ? (potw.slug ? `/product/${potw.slug}` : '/shop') : '#';
---
<Layout title={`Магазин · ${sf.name}`} storefront={sf}>
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Магазин</span></nav>
    </div>

    <!-- PRODUCT OF THE WEEK · optional highlight -->
    {potw && (
    <section class="section" style="background:var(--surface-2)">
      <div class="wrap">
        <div class="hero-grid" style="align-items:center">
          <a href={potwHref} class="ph ph--rounded" style="display:block;aspect-ratio:4/3">
            {potw.imageUrl ? (
              <img src={potw.imageUrl} alt={potw.name} loading="lazy"
                   style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" />
            ) : (
              <span class="ph__label">{potw.name}</span>
            )}
          </a>
          <div>
            <span class="eyebrow">★ Продукт на седмицата</span>
            <h2 style="margin-top:10px">{potw.name}</h2>
            {potwInfo?.note && <p class="lead" style="margin-top:14px;max-width:44ch">{potwInfo.note}</p>}
            <div class="product__price" style="font-size:30px;margin-top:16px">{money(potw.priceStotinki)}</div>
            <div class="cta-row" style="margin-top:20px">
              <a href={potwHref} class="btn btn--primary btn--lg">Виж продукта</a>
            </div>
          </div>
        </div>
      </div>
    </section>
    )}

    <section class="section--tight">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Магазин</span>
          <h2 style="margin-top:8px">Всичко от пазара на едно място</h2>
          <p>Избери категория. Продуктите идват от местните фермери и се запазват за петъчния пазар или за доставка до дома.</p>
        </div>

        {cats.length > 0 && (
          <div class="chips-row" data-tabs data-tabs-target="#catalogGrid"
               style="display:flex;gap:10px;flex-wrap:wrap;margin:28px 0 22px" id="catChips">
            <button class="chip is-active" data-tab="all">Всички</button>
            {cats.map((c) => <button class="chip" data-tab={c.id}>{c.name}</button>)}
          </div>
        )}

        <div class="grid grid--4" id="catalogGrid" data-tab-panels>
          {seeded
            ? active.map((p) => (
                <ProductCard product={p} stepper farmerName={farmerName(p.farmerId)} cat={catIdOf(p, sf.multiSubcat)} />
              ))
            : <p style="grid-column:1/-1;text-align:center;color:var(--muted);padding:48px 0">Все още няма продукти.</p>}
        </div>
      </div>
    </section>
  </main>
  <script>
    // Deep link: /shop#<categoryId> activates that category chip on load.
    const hash = decodeURIComponent(location.hash.replace('#', ''));
    if (hash) {
      const chip = document.querySelector<HTMLElement>(`#catChips [data-tab="${CSS.escape(hash)}"]`);
      chip?.click();
    }
  </script>
</Layout>
