---
import Layout from '../components/Layout.astro';
import CopySlot from '../components/CopySlot.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCatalog } from '../lib/api';
import { categoriesFrom, catIdOf, featured } from '../lib/catalog';

const boot = await getCatalog();
const { storefront: sf, products, farmers, subcategories: subcats } = boot;
const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const active = products.filter((p) => p.isActive !== false);
const seeded = active.length > 0;
// „Най-продавани" chip — gated on the toggle. Membership = the sales-ranked ids
// from the bootstrap (∩ the active catalog), padded with featured/newest up to 8
// so the chip is never thin on a quiet shop. The chip filters by this set; cards
// keep their catalog order within it.
const BEST_SELLER_CAP = 8;
const bestSellersOn = sf.merchandising?.bestSellers?.show ?? false;
const activeIds = new Set(active.map((p) => p.id));
const bestSellerSet = new Set((boot.bestSellerIds ?? []).filter((id) => activeIds.has(id)));
if (bestSellersOn) {
  for (const p of featured(active, active.length)) {
    if (bestSellerSet.size >= BEST_SELLER_CAP) break;
    bestSellerSet.add(p.id);
  }
}
const showBestChip = bestSellersOn && bestSellerSet.size > 0;
const farmerName = (id: string | null) => farmers.find((f) => f.id === id)?.name ?? null;
// Per-product availability map: productId → remaining (defensive: field absent on older backends).
const availMap = new Map((boot.availability ?? []).map((w: { productId: string; remaining: number }) => [w.productId, w.remaining]));
---
<Layout title={`Магазин · ${sf.name}`} storefront={sf}>
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Магазин</span></nav>
    </div>

    <section class="section--tight" data-copy-section="shop.head">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow"><CopySlot slot="shop.head.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="shop.head.title" copy={sf.copy} /></h2>
          <p><CopySlot slot="shop.head.text" copy={sf.copy} /></p>
        </div>

        {(cats.length > 0 || showBestChip) && (
          <div class="chips-row" data-tabs data-tabs-target="#catalogGrid"
               style="display:flex;gap:10px;flex-wrap:wrap;margin:28px 0 22px" id="catChips">
            <button class="chip is-active" data-tab="all">Всички</button>
            {showBestChip && <button class="chip" data-tab="best-sellers">Най-продавани</button>}
            {cats.map((c) => <button class="chip" data-tab={c.id}>{c.name}</button>)}
          </div>
        )}

        <div class="grid grid--4" id="catalogGrid" data-tab-panels>
          {seeded
            ? active.map((p) => (
                <ProductCard product={p} stepper farmerName={farmerName(p.farmerId)} cat={catIdOf(p, sf.multiSubcat)}
                  remaining={availMap.has(p.id) ? (availMap.get(p.id) ?? null) : null}
                  bestSeller={bestSellerSet.has(p.id)} />
              ))
            : <p style="grid-column:1/-1;text-align:center;color:var(--muted);padding:48px 0">Все още няма продукти.</p>}
        </div>
      </div>
    </section>
  </main>
  <script>
    // Deep link: /shop#<categoryId> activates that category chip on load.
    const hash = decodeURIComponent(location.hash.replace('#', ''));
    if (hash) {
      const chip = document.querySelector<HTMLElement>(`#catChips [data-tab="${CSS.escape(hash)}"]`);
      chip?.click();
    }
  </script>
</Layout>
