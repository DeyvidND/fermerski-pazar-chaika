---
import Layout from '../components/Layout.astro';
import CopySlot from '../components/CopySlot.astro';
import ProductCard from '../components/ProductCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCatalog } from '../lib/api';
import { categoriesFrom, catIdOf } from '../lib/catalog';
import { ONLY_LOCAL_DELIVERY } from '../lib/config';
import { itemListLd } from '../lib/jsonld';
import { farmerSlugMap } from '../lib/farmer-slug';

const boot = await getCatalog();
const { storefront: sf, products, farmers, subcategories: subcats } = boot;
const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const active = products.filter((p) => p.isActive !== false);
const seeded = active.length > 0;
// „Най-продавани" chip — gated on the toggle. Membership = ONLY the real
// sales-ranked ids from the bootstrap (∩ the active catalog). No padding with
// featured/newest, so the chip reflects genuine best-sellers (or stays hidden
// on a shop with no sales yet). The chip filters by this set.
const bestSellersOn = sf.merchandising?.bestSellers?.show ?? false;
const activeIds = new Set(active.map((p) => p.id));
const bestSellerSet = new Set((boot.bestSellerIds ?? []).filter((id) => activeIds.has(id)));
const showBestChip = bestSellersOn && bestSellerSet.size > 0;
// Collision-safe slug per farmer (see lib/farmer-slug.ts).
const slugs = farmerSlugMap(farmers);
const farmerName = (id: string | null) => farmers.find((f) => f.id === id)?.name ?? null;
const farmerImg = (id: string | null) => {
  const f = farmers.find((x) => x.id === id);
  return f?.images?.[0] ?? f?.imageUrl ?? null;
};
// Gated on ONLY_LOCAL_DELIVERY (../lib/config) — courier is checkout-locked
// storefront-wide right now, so no badge/chip may promise it either.
const farmerCourierReady = (id: string | null) =>
  !ONLY_LOCAL_DELIVERY && (farmers.find((f) => f.id === id)?.courierReady ?? false);
// Show the courier chip only if at least one active product can ship by courier.
const showCourierChip = active.some((p) => farmerCourierReady(p.farmerId) && !(p.courierDisabled ?? false));
// Per-product availability map: productId → remaining (defensive: field absent on older backends).
const availMap = new Map((boot.availability ?? []).map((w: { productId: string; remaining: number }) => [w.productId, w.remaining]));
// Farmer filter — a compact <select> (not another chip row) so 10-40 farmers stay
// elder-friendly. Gated on multiFarmer + >1 farmer total; options are only the
// farmers who actually have an active product right now (an empty pick is useless).
const activeFarmerIds = new Set(active.map((p) => p.farmerId).filter((id): id is string => !!id));
const filterableFarmers = farmers.filter((f) => activeFarmerIds.has(f.id));
const showFarmerFilter = sf.multiFarmer && filterableFarmers.length > 1;
// SEO: ItemList of the active catalog (products without a slug have no public
// URL, so they're excluded — capped at 50 inside itemListLd). Omitted entirely
// on a not-yet-seeded shop rather than emitting an empty list.
const shopMetaDesc = `Онлайн магазин с плодове, зеленчуци, мляко, мед и месо от местните фермери на ${sf.name} — с доставка и вземане от място.`;
const shopListItems = active.filter((p) => p.slug).map((p) => ({ name: p.name, path: `/product/${p.slug}` }));
const structuredData = shopListItems.length ? itemListLd(shopListItems) : undefined;
---
<Layout title={`Магазин · ${sf.name}`} description={shopMetaDesc} storefront={sf} jsonLd={structuredData} pageLabel="Магазин">
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Магазин</span></nav>
    </div>

    <section class="section--tight" data-copy-section="shop.head">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow"><CopySlot slot="shop.head.eyebrow" copy={sf.copy} /></span>
          <h1 style="margin-top:8px"><CopySlot slot="shop.head.title" copy={sf.copy} /></h1>
          <p><CopySlot slot="shop.head.text" copy={sf.copy} /></p>
        </div>

        {seeded && (
          <div class="shop-search">
            <SearchBar id="shopSearch" placeholder="Търси продукт или фермер…" />
          </div>
        )}

        {(cats.length > 0 || showBestChip) && (
          <div class="chips-row" id="catChips">
            <button class="chip is-active" data-tab="all" aria-pressed="true">Всички</button>
            {showBestChip && <button class="chip" data-tab="best-sellers" aria-pressed="false">Най-продавани</button>}
            {cats.map((c) => <button class="chip" data-tab={c.id} aria-pressed="false">{c.name}</button>)}
            {showCourierChip && (
              <button class="chip" id="courierChip" data-courier-filter aria-pressed="false" style="border-color:var(--primary);color:var(--primary)">
                📦 С куриер
              </button>
            )}
          </div>
        )}

        {showFarmerFilter && (
          <div class="field shop-farmer">
            <label for="farmerFilter">Филтър по фермер</label>
            <select id="farmerFilter" class="input">
              <option value="all">Всички фермери</option>
              {filterableFarmers.map((f) => <option value={f.id}>{f.name}</option>)}
            </select>
          </div>
        )}

        {seeded && (
          <p class="result-count" id="shopCount">{active.length === 1 ? '1 резултат' : `${active.length} резултата`}</p>
        )}

        <div class="grid grid--4" id="catalogGrid">
          {seeded
            ? active.map((p) => (
                <ProductCard product={p} stepper farmerName={farmerName(p.farmerId)}
                  farmerCourierReady={farmerCourierReady(p.farmerId)}
                  farmerId={p.farmerId} farmerSlug={p.farmerId ? slugs.get(p.farmerId) : null}
                  farmerImage={farmerImg(p.farmerId)}
                  cat={catIdOf(p, sf.multiSubcat)}
                  remaining={availMap.has(p.id) ? (availMap.get(p.id) ?? null) : null}
                  bestSeller={bestSellerSet.has(p.id)} />
              ))
            : <p style="grid-column:1/-1;text-align:center;color:var(--muted);padding:48px 0">Все още няма продукти.</p>}
        </div>
        {seeded && (
          <p id="shopEmpty" style="text-align:center;color:var(--muted);padding:40px 0" hidden></p>
        )}
      </div>
    </section>
  </main>
  <script>
    // Unified catalog filter: category chip + „С куриер" + text search all
    // compose (AND) through one apply() so they never fight over `display`.
    import { wireSearch } from '../scripts/search';

    const chips = document.getElementById('catChips');
    const grid = document.getElementById('catalogGrid');
    const countEl = document.getElementById('shopCount');
    const emptyEl = document.getElementById('shopEmpty');
    const cards = grid ? Array.from(grid.querySelectorAll<HTMLElement>('[data-product]')) : [];

    const state = { cat: 'all', courierOnly: false, q: '', farmer: 'all' };

    function apply() {
      let visible = 0;
      for (const card of cards) {
        const matchCat =
          state.cat === 'all' ||
          card.dataset.cat === state.cat ||
          (state.cat === 'best-sellers' && card.dataset.bestseller === '1');
        const matchCourier = !state.courierOnly || card.dataset.courier === '1';
        const matchText = state.q === '' || (card.dataset.name || '').includes(state.q);
        const matchFarmer = state.farmer === 'all' || card.dataset.farmer === state.farmer;
        const show = matchCat && matchCourier && matchText && matchFarmer;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      if (countEl) {
        // Always visible (SSR seeds it with the full count); keep it current.
        countEl.textContent = visible === 1 ? '1 резултат' : `${visible} резултата`;
      }
      if (emptyEl) {
        emptyEl.hidden = visible !== 0;
        emptyEl.textContent = state.q
          ? `Няма намерени продукти за „${state.q}“`
          : 'Няма продукти за този филтър';
      }
    }

    // Category chips (delegated). Courier chip has no data-tab, so it's ignored here.
    chips?.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>('[data-tab]');
      if (!chip) return;
      chips.querySelectorAll<HTMLElement>('[data-tab]').forEach((c) => {
        c.classList.toggle('is-active', c === chip);
        c.setAttribute('aria-pressed', String(c === chip));
      });
      state.cat = chip.dataset.tab || 'all';
      apply();
    });

    // „С куриер" chip — independent toggle, composes with category + text.
    const courierChip = document.getElementById('courierChip');
    courierChip?.addEventListener('click', () => {
      state.courierOnly = !state.courierOnly;
      courierChip.classList.toggle('is-active', state.courierOnly);
      courierChip.setAttribute('aria-pressed', String(state.courierOnly));
      apply();
    });

    // Text search.
    wireSearch('shopSearch', (q) => {
      state.q = q;
      apply();
    });

    // Farmer filter — compact <select>, composes with category + courier + text.
    const farmerFilter = document.getElementById('farmerFilter') as HTMLSelectElement | null;
    farmerFilter?.addEventListener('change', () => {
      state.farmer = farmerFilter.value || 'all';
      apply();
    });

    // Deep link: /shop#<categoryId> activates that category chip on load.
    const hash = decodeURIComponent(location.hash.replace('#', ''));
    if (hash) {
      const chip = chips?.querySelector<HTMLElement>(`[data-tab="${CSS.escape(hash)}"]`);
      chip?.click();
    }
  </script>
</Layout>
