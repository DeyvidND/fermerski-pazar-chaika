---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';
import CopySlot from '../components/CopySlot.astro';
import { getStorefront, FALLBACK_STOREFRONT } from '../lib/api';
import { telHref, resolveSocials, contactPhone, contactEmail, customFields, contactValueHref, contactAddress, contactHours, mapEmbedSrc } from '../lib/site';

const sf = (await getStorefront()) ?? FALLBACK_STOREFRONT;
const phone = contactPhone(sf);
const email = contactEmail(sf);
const extra = customFields(sf);
const socials = resolveSocials(sf);
const address = contactAddress(sf);
const hours = contactHours(sf);
const mapSrc = mapEmbedSrc(sf);
---
<Layout title={`Контакти · ${sf.name}`} storefront={sf}>
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Контакти</span></nav>
    </div>

    <section class="section--tight" data-copy-section="contact.head">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow"><CopySlot slot="contact.head.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="contact.head.title" copy={sf.copy} /></h2>
          <p><CopySlot slot="contact.head.text" copy={sf.copy} /></p>
        </div>

        <div class="split" style="margin-top:30px;align-items:flex-start">
          <div class="stack" style="gap:18px">
            <div class="grid grid--2" style="gap:14px">
              {phone && (
                <a href={telHref(phone)} class="card" style="padding:20px;display:flex;gap:14px;align-items:center">
                  <span class="contact-ic"><Icon name="phone" /></span>
                  <span><span class="muted" style="font-size:13px">Телефон / Viber</span><br><b>{phone}</b></span>
                </a>
              )}
              {email && (
                <a href={`mailto:${email}`} class="card" style="padding:20px;display:flex;gap:14px;align-items:center">
                  <span class="contact-ic"><Icon name="mail" /></span>
                  <span><span class="muted" style="font-size:13px">Имейл</span><br><b>{email}</b></span>
                </a>
              )}
            </div>

            <div class="card" style="padding:20px;display:flex;gap:14px;align-items:center">
              <span class="contact-ic"><Icon name="pin" /></span>
              <span><span class="muted" style="font-size:13px">Пазар на място</span><br><b>{address}</b> · {hours}</span>
            </div>

            {extra.map((f) => {
              const href = contactValueHref(f.value);
              const ic = href?.startsWith('mailto:') ? 'mail' : href?.startsWith('tel:') ? 'phone' : href ? 'globe' : 'leaf';
              return (
                <div class="card" style="padding:20px;display:flex;gap:14px;align-items:center">
                  <span class="contact-ic"><Icon name={ic} /></span>
                  <span>
                    {f.label && <Fragment><span class="muted" style="font-size:13px">{f.label}</span><br></Fragment>}
                    {href ? <a href={href}><b>{f.value}</b></a> : <b>{f.value}</b>}
                  </span>
                </div>
              );
            })}

            <iframe
              class="contact-map"
              src={mapSrc}
              title="Карта · кв. Чайка, Варна"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>

            <div>
              <div class="muted" style="font-size:13.5px;margin-bottom:10px">Последвай ни</div>
              <div class="socials" style="margin:0">
                {socials.map((s) => (
                  <a href={s.href} aria-label={s.label} target="_blank" rel="noopener" style="background:var(--primary-050);color:var(--primary)"><Icon name={s.icon} /></a>
                ))}
              </div>
            </div>
          </div>

          <div class="card" style="padding:clamp(22px,3vw,34px)" data-copy-section="contact.form">
            <h3 style="font-size:24px;margin-bottom:6px"><CopySlot slot="contact.form.title" copy={sf.copy} /></h3>
            <p class="muted" style="margin-bottom:22px"><CopySlot slot="contact.form.note" copy={sf.copy} /></p>
            <form class="stack" style="gap:14px" data-api-form="contact">
              <div class="field-row">
                <div class="field"><label>Име</label><input class="input" name="name" placeholder="Твоето име" required /></div>
                <div class="field"><label>Телефон</label><input class="input" name="phone" type="tel" placeholder="+359 ..." /></div>
              </div>
              <div class="field"><label>Имейл</label><input class="input" name="email" type="email" placeholder="ime@example.bg" required /></div>
              <div class="field"><label>Съобщение</label><textarea class="textarea" name="message" placeholder="Как можем да помогнем?" required></textarea></div>
              <button class="btn btn--primary" type="submit" style="align-self:flex-start">Изпрати</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script>
    import '../scripts/forms.ts';
  </script>
</Layout>
