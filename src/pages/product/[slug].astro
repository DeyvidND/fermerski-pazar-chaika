---
import Layout from '../../components/Layout.astro';
import Icon from '../../components/Icon.astro';
import ProductCard from '../../components/ProductCard.astro';
import Gallery from '../../components/Gallery.astro';
import { getStorefront, getProduct, getProducts, getFarmers, getSubcategories, FALLBACK_STOREFRONT } from '../../lib/api';
import { money } from '../../lib/money';
import { featured } from '../../lib/catalog';

const { slug } = Astro.params;
const [sfRaw, product, products, farmers, subcats] = await Promise.all([
  getStorefront(),
  getProduct(slug!),
  getProducts(),
  getFarmers(),
  getSubcategories(),
]);
const sf = sfRaw ?? FALLBACK_STOREFRONT;

if (!product) {
  return Astro.redirect('/404');
}

const farmer = farmers.find((f) => f.id === product.farmerId) ?? null;
const catName = sf.multiSubcat
  ? subcats.find((s) => s.id === product.subcategoryId)?.name ?? null
  : product.category && product.category !== 'bundle'
    ? product.category
    : null;
const related = featured(products.filter((p) => p.id !== product.id), 4);
const productImages = product.images?.length
  ? product.images
  : product.imageUrl
    ? [product.imageUrl]
    : [];
const priceLv = (product.priceStotinki / 100).toFixed(2);
const metaBits = [product.weight, farmer?.name].filter(Boolean).join(' · ');
const tag = product.featured ? '★ Популярен' : product.compareAtPriceStotinki ? 'Промо' : null;
---
<Layout title={`${product.name} · ${sf.name}`} storefront={sf}>
  <main data-product>
    <div class="wrap">
      <nav class="breadcrumb">
        <a href="/">Начало</a> / <a href="/shop">Магазин</a> / <span>{product.name}</span>
      </nav>
    </div>

    <section class="section--tight">
      <div class="wrap split" style="align-items:flex-start">
        <div>
          <Gallery images={productImages} alt={product.name} label={`${product.name} · 1:1`} />
        </div>
        <div>
          {tag && <span class="tag">{tag}</span>}
          <h1 style="font-size:clamp(34px,5vw,52px);margin:14px 0 6px">{product.name}</h1>
          {metaBits && <div class="muted" style="font-size:16px">{metaBits}</div>}
          <div class="product__price" style="font-size:34px;margin:18px 0">
            {money(product.priceStotinki)}
            {product.compareAtPriceStotinki && (
              <span class="muted" style="font-size:20px;font-weight:500;text-decoration:line-through;margin-left:10px">
                {money(product.compareAtPriceStotinki)}
              </span>
            )}
          </div>
          {product.description && <p class="lead" style="font-size:17px">{product.description}</p>}
          {!product.description && (
            <p class="lead" style="font-size:17px">
              Свеж продукт от местен фермер{catName ? `, категория „${catName}“` : ''}. Запази за петъчния пазар на Чайка или поръчай с доставка до дома.
            </p>
          )}

          {product.bundleItems && product.bundleItems.length > 0 && (
            <ul class="market-facts" style="margin-top:18px">
              {product.bundleItems.map((it) => (
                <li><span class="fic"><Icon name="check" /></span><div><b>{it}</b></div></li>
              ))}
            </ul>
          )}

          <div class="note-fresh" style="margin:22px 0"><Icon name="leaf" /> Свежо за петъчния пазар</div>
          <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap;margin-top:8px">
            <div class="stepper" aria-label="Количество">
              <button data-dir="down" aria-label="по-малко">−</button>
              <input type="number" value="1" min="1" inputmode="numeric" />
              <button data-dir="up" aria-label="повече">+</button>
            </div>
            <button class="btn btn--primary btn--lg" data-add-cart
              data-id={product.id} data-name={product.name} data-price={priceLv} data-weight={product.weight || ''}>
              Добави в количка
            </button>
          </div>

          {farmer && (
            <div class="card" style="margin-top:26px;padding:18px;box-shadow:none;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap">
              <span><span class="muted" style="font-size:13px">Фермер</span><br><b>{farmer.name}</b></span>
              <a href={`/farmer/${farmer.id}`} class="btn btn--soft btn--sm">Виж стопанството</a>
            </div>
          )}
        </div>
      </div>
    </section>

    {related.length > 0 && (
      <section class="section--tight">
        <div class="wrap">
          <h2 style="font-size:28px;margin-bottom:22px">Други от пазара</h2>
          <div class="grid grid--4">
            {related.map((p) => <ProductCard product={p} />)}
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>
