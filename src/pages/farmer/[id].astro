---
import Layout from '../../components/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Gallery from '../../components/Gallery.astro';
import { getCatalog } from '../../lib/api';
import { categoriesFrom, farmerSubsections } from '../../lib/catalog';
import { imageOrigin } from '../../lib/site';

const { id } = Astro.params;
// One /bootstrap round trip (shared memo) instead of four separate reads.
const { storefront: sf, farmers, products, subcategories: subcats } = await getCatalog();
const farmer = farmers.find((f) => f.id === id) ?? null;

if (!farmer) {
  return Astro.redirect('/farmers');
}

const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const subsections = farmerSubsections(farmer.id, products, cats, sf.multiSubcat);
const totalProducts = subsections.reduce((n, s) => n + s.products.length, 0);
const farmerImages = farmer.images?.length
  ? farmer.images
  : farmer.imageUrl
    ? [farmer.imageUrl]
    : [];
const eyebrow = [farmer.role, farmer.since ? 'от ' + farmer.since : null].filter(Boolean).join(' · ');
const yearsWithUs = farmer.since && /^\d{4}$/.test(farmer.since) ? 2026 - Number(farmer.since) : null;
const imgOrigin = imageOrigin(farmerImages[0]);
---
<Layout title={`${farmer.name} · ${sf.name}`} storefront={sf} imageOrigin={imgOrigin}>
  <main>
    <div class="wrap">
      <nav class="breadcrumb">
        <a href="/">Начало</a> / <a href="/farmers">Фермери</a> / <span>{farmer.name}</span>
      </nav>
    </div>

    <section class="section--tight">
      <div class="wrap">
        <div class="farmer-hero">
          <Gallery images={farmerImages} alt={farmer.name} label={farmer.name} />
          <div>
            {eyebrow && <span class="eyebrow">{eyebrow}</span>}
            <h1 style="font-size:clamp(34px,5vw,56px);margin:12px 0 8px">{farmer.name}</h1>
            {farmer.role && <div class="muted" style="font-weight:600;font-size:15px">{farmer.role}</div>}
            {farmer.bio && <p class="lead" style="margin-top:18px">{farmer.bio}</p>}
            <div class="farmer-hero__meta">
              <div><div class="n">{totalProducts}</div><div class="l">продукта</div></div>
              <div><div class="n">{subsections.length}</div><div class="l">категории</div></div>
              {yearsWithUs && <div><div class="n">{yearsWithUs}+</div><div class="l">години с нас</div></div>}
            </div>
            <div class="cta-row">
              {subsections.length > 0 && (
                <a href={`#${encodeURIComponent(subsections[0].cat.id)}`} class="btn btn--primary">Виж продуктите</a>
              )}
              <a href="/contact" class="btn btn--ghost">Свържи се с фермера</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {subsections.length > 0 && (
      <section class="section--tight" style="padding-top:0">
        <div class="wrap">
          <div class="sub-nav">
            {subsections.map((s) => (
              <a href={`#${encodeURIComponent(s.cat.id)}`} class="chip">{s.cat.name} · {s.products.length}</a>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="wrap">
      {subsections.map((s) => (
        <section class="subsection" id={s.cat.id}>
          <div class="subsection__head">
            <div>
              <span class="eyebrow">Категория</span>
              <h2 style="margin-top:6px">{s.cat.name}</h2>
              {s.cat.desc && <p>{s.cat.desc}</p>}
            </div>
            <a href={`/shop#${encodeURIComponent(s.cat.id)}`} class="btn btn--soft btn--sm">Виж всички в „{s.cat.name}“</a>
          </div>
          <div class="grid grid--4">
            {s.products.map((p) => <ProductCard product={p} stepper cat={s.cat.id} />)}
          </div>
        </section>
      ))}
    </div>

    <div style="height:48px"></div>
  </main>
</Layout>
