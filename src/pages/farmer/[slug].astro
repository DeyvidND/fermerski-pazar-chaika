---
import Layout from '../../components/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Gallery from '../../components/Gallery.astro';
import Icon from '../../components/Icon.astro';
import { getCatalog } from '../../lib/api';
import { categoriesFrom, farmerSubsections } from '../../lib/catalog';
import { imageOrigin, telHref } from '../../lib/site';
import { cfImage } from '../../lib/img';
import { farmerLd, breadcrumbLd } from '../../lib/jsonld';
import { allVariantsSoldOut } from '../../lib/pricing';
import { resolveFarmer } from '../../lib/farmer-slug';

const { slug } = Astro.params;
// One /bootstrap round trip (shared memo) instead of four separate reads.
const boot = await getCatalog();
const { storefront: sf, farmers, products, subcategories: subcats } = boot;
const { farmer, canonicalSlug, needsRedirect } = resolveFarmer(farmers, slug);

if (!farmer) {
  // Unknown farmer slug/id → real HTTP 404, not a soft-404 redirect to the list.
  return Astro.rewrite('/404');
}

if (needsRedirect && canonicalSlug) {
  // Old id-based link (pre-slug) → 301 to the canonical name-slug URL,
  // preserving whatever SEO equity/backlinks pointed at the old /farmer/<uuid>.
  return Astro.redirect(`/farmer/${canonicalSlug}`, 301);
}

// Per-product availability map: productId → remaining. Without this, product
// cards here never showed "в наличност"/"изчерпан" — the only page that didn't,
// unlike shop.astro and product/[slug].astro.
const availMap = new Map((boot.availability ?? []).map((w: { productId: string; remaining: number }) => [w.productId, w.remaining]));

const cats = categoriesFrom(products, subcats, sf.multiSubcat);
const subsections = farmerSubsections(farmer.id, products, cats, sf.multiSubcat);
const totalProducts = subsections.reduce((n, s) => n + s.products.length, 0);
const farmerImages = farmer.images?.length
  ? farmer.images
  : farmer.imageUrl
    ? [farmer.imageUrl]
    : [];
const eyebrow = [farmer.role, farmer.since ? 'от ' + farmer.since : null].filter(Boolean).join(' · ');
const yearsWithUs = farmer.since && /^\d{4}$/.test(farmer.since) ? 2026 - Number(farmer.since) : null;
const imgOrigin = imageOrigin(farmerImages[0]);

// SEO: bio/role as meta description, photo as social image, breadcrumb data.
const metaDesc =
  farmer.bio?.replace(/\s+/g, ' ').trim().slice(0, 160) ||
  `${farmer.name}${eyebrow ? ` · ${eyebrow}` : ''} — ${sf.name}.`;
const ogImage = cfImage(farmerImages[0], 1200) ?? null;
// This farmer's active, in-stock products — feeds the Organization node's
// OfferCatalog below (never the full unfiltered catalog).
const farmerInStockProducts = products.filter((p) => {
  if (p.farmerId !== farmer.id || p.isActive === false) return false;
  if (allVariantsSoldOut(p)) return false;
  const remaining = availMap.get(p.id);
  return !(remaining !== undefined && remaining === 0);
});
const structuredData = [
  farmerLd(farmer, sf, farmerInStockProducts),
  breadcrumbLd([
    { name: 'Начало', path: '/' },
    { name: 'Фермери', path: '/farmers' },
    { name: farmer.name, path: `/farmer/${canonicalSlug}` },
  ]),
];
---
<Layout title={`${farmer.name} · ${sf.name}`} description={metaDesc} storefront={sf} imageOrigin={imgOrigin} image={ogImage} jsonLd={structuredData} pageLabel="Профил на фермер">
  <main>
    <div class="wrap">
      <nav class="breadcrumb">
        <a href="/">Начало</a> / <a href="/farmers">Фермери</a> / <span>{farmer.name}</span>
      </nav>
    </div>

    <section class="section--tight">
      <div class="wrap">
        <div class="farmer-hero">
          <Gallery images={farmerImages} alt={farmer.name} label={farmer.name} />
          <div>
            {eyebrow && <span class="eyebrow">{eyebrow}</span>}
            <h1 style="font-size:clamp(34px,5vw,56px);margin:12px 0 8px">{farmer.name}</h1>
            {farmer.role && <div class="muted" style="font-weight:600;font-size:15px">{farmer.role}</div>}
            {farmer.bio && <p class="lead" style="margin-top:18px">{farmer.bio}</p>}
            <div class="farmer-hero__meta">
              <div><div class="n">{totalProducts}</div><div class="l">продукта</div></div>
              <div><div class="n">{subsections.length}</div><div class="l">категории</div></div>
              {yearsWithUs && <div><div class="n">{yearsWithUs}+</div><div class="l">години с нас</div></div>}
            </div>
            {(farmer.phone || farmer.email || farmer.legal?.address) && (
              <div class="farmer-contact">
                {farmer.phone && <a href={telHref(farmer.phone)}><Icon name="phone" />{farmer.phone}</a>}
                {farmer.email && <a href={`mailto:${farmer.email}`}><Icon name="mail" />{farmer.email}</a>}
                {farmer.legal?.address && <span><Icon name="pin" />{farmer.legal.address}</span>}
              </div>
            )}
            {farmer.legal?.name && (
              <div style="margin-top:18px;padding:14px 16px;border:1px solid var(--border,#e5e2d9);border-radius:12px;background:var(--surface-2,#faf9f5);font-size:13.5px;line-height:1.6">
                <div style="font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:11.5px;color:var(--muted,#6f7a69);margin-bottom:4px">Продавач</div>
                <div style="font-weight:700;font-size:15px">{farmer.legal.name}</div>
                <div style="color:var(--muted,#6f7a69);margin-top:2px">
                  {(farmer.legal.eik || farmer.legal.regNo) && (
                    <span>{farmer.legal.eik ? `ЕИК/БУЛСТАТ ${farmer.legal.eik}` : `Рег. № зем. производител ${farmer.legal.regNo}`}</span>
                  )}
                  {farmer.legal.vatNumber && <span> · ДДС № {farmer.legal.vatNumber}</span>}
                  {farmer.legal.address && <span> · {farmer.legal.address}</span>}
                </div>
                <p style="margin:8px 0 0;font-size:12px;color:var(--muted,#6f7a69)">
                  Продавач по договора за поръчката е този производител. Пазарът предоставя онлайн мястото за търговия като посредник.
                </p>
              </div>
            )}
            <div class="cta-row">
              {subsections.length > 0 && (
                <a href={`#${encodeURIComponent(subsections[0].cat.id)}`} class="btn btn--primary">Виж продуктите</a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    {subsections.length > 0 && (
      <section class="section--tight" style="padding-top:0">
        <div class="wrap">
          <div class="sub-nav">
            {subsections.map((s) => (
              <a href={`#${encodeURIComponent(s.cat.id)}`} class="chip">{s.cat.name} · {s.products.length}</a>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="wrap">
      {subsections.map((s) => (
        <section class="subsection" id={s.cat.id}>
          <div class="subsection__head">
            <div>
              <span class="eyebrow">Категория</span>
              <h2 style="margin-top:6px">{s.cat.name}</h2>
              {s.cat.desc && <p>{s.cat.desc}</p>}
            </div>
            <a href={`/shop#${encodeURIComponent(s.cat.id)}`} class="btn btn--soft btn--sm">Виж всички в „{s.cat.name}“</a>
          </div>
          <div class="grid grid--4">
            {s.products.map((p) => <ProductCard product={p} stepper cat={s.cat.id} remaining={availMap.has(p.id) ? (availMap.get(p.id) ?? null) : null} />)}
          </div>
        </section>
      ))}
    </div>

    <div style="height:48px"></div>
  </main>
</Layout>
