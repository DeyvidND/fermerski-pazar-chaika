---
import Layout from '../components/Layout.astro';
import { getCatalog } from '../lib/api';
import { farmerSlugMap } from '../lib/farmer-slug';
import { resolveMapPoints } from '../lib/farmer-map';

export const prerender = false;

// Browser Google Maps key — read at REQUEST time. On this Cloudflare Workers
// deploy, `Astro.locals.runtime.env` (the Worker's bindings, via
// `platformProxy` in dev too — see astro.config.mjs) is the correct source;
// `globalThis.process?.env` is a legacy Dokploy-container idiom (still used by
// checkout.astro, a known unresolved TODO — see CLOUDFLARE.md #1) that does
// NOT reliably resolve on Workers, which silently disabled this page's map.
// `import.meta.env` covers plain `astro dev` without wrangler. Empty key →
// the map stays off and the fallback village list is the page.
const runtimeBindings = (Astro.locals as any)?.runtime?.env ?? {};
const processEnv = (globalThis as any).process?.env ?? {};
const mapsKey = String(
  runtimeBindings.PUBLIC_GOOGLE_MAPS_KEY ??
    processEnv.PUBLIC_GOOGLE_MAPS_KEY ??
    import.meta.env.PUBLIC_GOOGLE_MAPS_KEY ??
    '',
).trim();

const { storefront: sf, farmers } = await getCatalog();
const slugs = farmerSlugMap(farmers);
const points = resolveMapPoints(farmers, slugs);

const metaDesc = `Виж на картата откъде идват фермерите и стопанствата зад продуктите на ${sf.name}.`;
---
<Layout title={`Карта на фермерите · ${sf.name}`} description={metaDesc} storefront={sf} pageLabel="Карта">
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Карта</span></nav>
    </div>

    <section class="section--tight">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Откъде идва храната</span>
          <h1 style="margin-top:8px">Карта на фермерите</h1>
          <p>Нашите фермери и стопанства из България — по адреса на стопанството, където е известен.</p>
        </div>

        <div
          id="farmerMap"
          class="farmer-map"
          hidden
          data-maps-key={mapsKey}
          data-points={JSON.stringify(points)}
          aria-label="Карта с местоположението на фермерите"
        ></div>

        <!-- Village list: hidden by default; the client script reveals it only
             when the map can't run (no key / load failure), and <noscript>
             below reveals it when JS is off. So with a working map it never
             shows — no card grid stacked under the map. -->
        <ul id="mapFallback" class="map-fallback" hidden>
          {points.map((p) => (
            <li class="map-fallback__item">
              <span class="map-fallback__village">{p.village}</span>
              {p.slug
                ? <a class="map-fallback__name" href={`/farmer/${p.slug}`}>{p.name}</a>
                : <span class="map-fallback__name">{p.name}</span>}
            </li>
          ))}
        </ul>
        <noscript>
          <style>#mapFallback[hidden] { display: grid; }</style>
        </noscript>
      </div>
    </section>
  </main>

  <script>
    import '../scripts/farmer-map';
  </script>

  <style>
    .farmer-map {
      width: 100%;
      min-height: 460px;
      border-radius: var(--radius, 18px);
      overflow: hidden;
      border: 1px solid var(--line, #e2dac8);
      background: var(--surface-2, #f6f0e2);
      box-shadow: var(--shadow-sm, 0 2px 8px -3px rgba(44,85,48,.18));
    }
    .map-fallback {
      list-style: none;
      margin: 8px 0 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
    }
    /* `[hidden]`'s UA `display:none` is author-overridden by `display:grid`
       above, so make the hide explicit — else the list shows under the map. */
    .map-fallback[hidden] { display: none; }
    .map-fallback__item {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 14px 16px;
      border-radius: var(--radius-sm, 12px);
      background: var(--surface-2, #f6f0e2);
      border: 1px solid var(--line, #e2dac8);
    }
    .map-fallback__village { font-size: 13px; color: var(--muted, #686456); }
    .map-fallback__name { font-weight: 600; color: var(--ink, #25301f); text-decoration: none; }
    a.map-fallback__name:hover { color: var(--primary, #2c5530); text-decoration: underline; }
    @media (max-width: 480px) { .farmer-map { min-height: 380px; } }
  </style>

  <!-- Global (unscoped) so it reaches the popup element the client script
       injects into Google's map panes at runtime. Colors are theme.css's brand
       tokens, hardcoded because this DOM lives outside the page's cascade. -->
  <style is:global>
    .ff-popup {
      position: absolute;
      transform: translate(-50%, calc(-100% - 46px));
      pointer-events: none;
    }
    .ff-popup__card {
      position: relative;
      pointer-events: auto;
      min-width: 190px;
      max-width: 244px;
      padding: 15px 17px 16px;
      background: #FBF8F1;
      border: 1px solid #E2DAC8;
      border-radius: 16px;
      box-shadow: 0 20px 46px -20px rgba(44, 85, 48, .5);
      font-family: "Commissioner", system-ui, sans-serif;
    }
    .ff-popup__card::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -7px;
      width: 14px;
      height: 14px;
      transform: translateX(-50%) rotate(45deg);
      background: #FBF8F1;
      border-right: 1px solid #E2DAC8;
      border-bottom: 1px solid #E2DAC8;
    }
    .ff-popup__name {
      margin: 0 26px 6px 0;
      font-family: "Lora", Georgia, serif;
      font-weight: 600;
      font-size: 16.5px;
      line-height: 1.25;
      color: #25301F;
    }
    .ff-popup__village {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 12.5px;
      color: #686456;
    }
    .ff-popup__dot {
      width: 6px;
      height: 6px;
      flex: none;
      border-radius: 50%;
      background: #E8A33D;
    }
    .ff-popup__link {
      margin-top: 12px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 7px 14px;
      font-size: 13px;
      font-weight: 600;
      color: #2C5530;
      text-decoration: none;
      background: #E7EDE4;
      border-radius: 999px;
      transition: background .15s ease;
    }
    .ff-popup__link:hover { background: #DBE5D6; }
    .ff-popup__close {
      position: absolute;
      top: 9px;
      right: 10px;
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      font-size: 18px;
      line-height: 1;
      color: #A49D8B;
      background: transparent;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      transition: background .15s ease, color .15s ease;
    }
    .ff-popup__close:hover { background: #F1EAD9; color: #25301F; }
  </style>
</Layout>
