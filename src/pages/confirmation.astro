---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';
import { getStorefront, FALLBACK_STOREFRONT } from '../lib/api';
const sf = (await getStorefront()) ?? FALLBACK_STOREFRONT;
---
<Layout title={`Поръчката е приета · ${sf.name}`} storefront={sf}>
  <main>
    <section class="section">
      <div class="wrap" style="max-width:760px">
        <div class="center">
          <div style="width:88px;height:88px;border-radius:50%;background:var(--primary);color:#fff;display:grid;place-items:center;margin:0 auto 22px">
            <span style="width:40px;height:40px;display:grid;place-items:center"><Icon name="check" /></span>
          </div>
          <span class="eyebrow" id="orderNo">Поръчка приета</span>
          <h1 style="font-size:clamp(32px,5vw,52px);margin:10px 0 14px">Благодарим! Поръчката е приета</h1>
          <p class="lead">Изпратихме потвърждение на имейла ти. Ще се чуем по телефона, ако се наложи да уточним нещо.</p>
        </div>

        <div class="card" style="padding:28px;margin-top:32px">
          <div class="split" style="gap:24px;align-items:flex-start">
            <div>
              <h4 style="text-transform:uppercase;letter-spacing:.1em;font-size:12.5px;color:var(--muted);margin-bottom:8px">Получаване</h4>
              <div style="font-weight:600">Фермерски пазар · Чайка</div>
              <div class="muted">бул. „Ал. Стамболийски“, Варна</div>
              <div class="note-fresh" style="margin-top:12px" id="slotNote">Петък · 11:00–18:00</div>
            </div>
            <div>
              <h4 style="text-transform:uppercase;letter-spacing:.1em;font-size:12.5px;color:var(--muted);margin-bottom:8px">Поръчано</h4>
              <div id="recap"></div>
            </div>
          </div>
          <hr class="divider" style="margin:20px 0" />
          <div class="summary__row total" style="border:0;padding:0"><span>Платено</span><span id="paid">—</span></div>
        </div>

        <div class="grid grid--3" style="margin-top:28px">
          <div class="card value-card"><div class="ic"><Icon name="check" /></div><h3 style="font-size:18px">Потвърждение</h3><p style="font-size:14.5px">Получаваш имейл с детайлите веднага.</p></div>
          <div class="card value-card"><div class="ic"><Icon name="leaf" /></div><h3 style="font-size:18px">Свежо в петък</h3><p style="font-size:14.5px">Фермерите приготвят поръчката за петък.</p></div>
          <div class="card value-card"><div class="ic"><Icon name="basket" /></div><h3 style="font-size:18px">Вземаш на място</h3><p style="font-size:14.5px">Или куриерът ти го донася до вратата.</p></div>
        </div>

        <div class="center" style="margin-top:32px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
          <a href="/shop" class="btn btn--primary">Поръчай отново</a>
          <a href="/" class="btn btn--ghost">Към началото</a>
        </div>
      </div>
    </section>
  </main>
  <script>
    import '../scripts/confirmation-page.ts';
  </script>
</Layout>
