---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';
import MediaSlot from '../components/MediaSlot.astro';
import CopySlot from '../components/CopySlot.astro';
import { getStorefront, FALLBACK_STOREFRONT } from '../lib/api';
const sf = (await getStorefront()) ?? FALLBACK_STOREFRONT;
---
<Layout title={`Поръчки · ${sf.name}`} storefront={sf}>
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Поръчки</span></nav>
    </div>

    <section class="section--tight" data-copy-section="orders.head">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow"><CopySlot slot='orders.head.eyebrow' copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot='orders.head.title' copy={sf.copy} /></h2>
          <p><CopySlot slot='orders.head.text' copy={sf.copy} /></p>
        </div>
      </div>
    </section>

    <section class="section--tight">
      <div class="wrap">
        <div class="grid grid--2">
          <article class="card pillar" data-copy-section="orders.pickup">
            <MediaSlot slot="site.pillar_market" media={sf.media} />
            <div class="pillar__body">
              <span class="pillar__ic"><Icon name="basket" /></span>
              <h3><CopySlot slot='orders.pickup.title' copy={sf.copy} /></h3>
              <p><CopySlot slot='orders.pickup.text' copy={sf.copy} /></p>
              <ul class="pillar__facts">
                <li><span class="fic"><Icon name="pin" /></span> кв. Чайка, бул. „Ал. Стамболийски" (пред „Фратели")</li>
                <li><span class="fic"><Icon name="clock" /></span> Всеки петък · 11:00–18:00</li>
                <li><span class="fic"><Icon name="leaf" /></span> Без такса · плащаш на място</li>
              </ul>
              <a href="/shop" class="btn btn--soft">Запази продукти</a>
            </div>
          </article>
          <article class="card pillar" data-copy-section="orders.delivery">
            <MediaSlot slot="site.pillar_delivery" media={sf.media} />
            <div class="pillar__body">
              <span class="pillar__ic"><Icon name="truck" /></span>
              <h3><CopySlot slot='orders.delivery.title' copy={sf.copy} /></h3>
              <p><CopySlot slot='orders.delivery.text' copy={sf.copy} /></p>
              <ul class="pillar__facts">
                <li><span class="fic"><Icon name="truck" /></span> Доставка в петък · 11:00–20:00 ч.</li>
                <li><span class="fic"><Icon name="pin" /></span> Варна и близките квартали</li>
                <li><span class="fic"><Icon name="leaf" /></span> Безплатна доставка над 40,00 €</li>
              </ul>
              <a href="/shop" class="btn btn--soft">Поръчай онлайн</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" style="background:var(--surface-2)" data-copy-section="orders.steps">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:34px">
          <span class="eyebrow"><CopySlot slot='orders.steps.eyebrow' copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot='orders.steps.title' copy={sf.copy} /></h2>
        </div>
        <div class="grid grid--4">
          <div class="card value-card"><div class="ic"><Icon name="produce" /></div><h3><CopySlot slot='orders.steps.1.title' copy={sf.copy} /></h3><p><CopySlot slot='orders.steps.1.text' copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="cart" /></div><h3><CopySlot slot='orders.steps.2.title' copy={sf.copy} /></h3><p><CopySlot slot='orders.steps.2.text' copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="truck" /></div><h3><CopySlot slot='orders.steps.3.title' copy={sf.copy} /></h3><p><CopySlot slot='orders.steps.3.text' copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="check" /></div><h3><CopySlot slot='orders.steps.4.title' copy={sf.copy} /></h3><p><CopySlot slot='orders.steps.4.text' copy={sf.copy} /></p></div>
        </div>
      </div>
    </section>

    <section class="section" data-copy-section="orders.know">
      <div class="wrap">
        <div class="market-block">
          <div>
            <span class="eyebrow"><CopySlot slot='orders.know.eyebrow' copy={sf.copy} /></span>
            <h2 style="font-size:clamp(28px,4vw,40px);margin-top:10px"><CopySlot slot='orders.know.title' copy={sf.copy} /></h2>
            <ul class="market-facts">
              <li><span class="fic"><Icon name="clock" /></span><div><b>Краен срок за поръчки — четвъртък 20:00 ч.</b><span>за да влязат в петъчната доставка</span></div></li>
              <li><span class="fic"><Icon name="truck" /></span><div><b>Доставка в петък · 11:00–20:00 ч.</b><span>куриерът се обажда преди да пристигне</span></div></li>
            </ul>
            <div class="cta-row" style="margin-top:26px">
              <a href="/shop" class="btn btn--primary">Към магазина</a>
              <a href="/faq" class="btn btn--ghost">Чести въпроси</a>
            </div>
          </div>
          <MediaSlot slot="orders.box" media={sf.media} />
        </div>
      </div>
    </section>
  </main>
</Layout>
