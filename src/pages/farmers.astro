---
import Layout from '../components/Layout.astro';
import CopySlot from '../components/CopySlot.astro';
import Icon from '../components/Icon.astro';
import FarmerCard from '../components/FarmerCard.astro';
import GhostFarmerCard from '../components/GhostFarmerCard.astro';
import AdminNote from '../components/AdminNote.astro';
import { getCatalog } from '../lib/api';
import { catIdOf } from '../lib/catalog';

// One /bootstrap round trip (shared memo) instead of three separate reads.
const { storefront: sf, farmers, products } = await getCatalog();
const farmerCount = (id: string) => products.filter((p) => p.farmerId === id).length;
const farmerCats = (id: string) =>
  new Set(products.filter((p) => p.farmerId === id).map((p) => catIdOf(p, sf.multiSubcat))).size;
---
<Layout title={`Фермери · ${sf.name}`} storefront={sf} pageLabel="Фермери">
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Фермери</span></nav>
    </div>

    <section class="section--tight" data-copy-section="farmers.head">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow"><CopySlot slot="farmers.head.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="farmers.head.title" copy={sf.copy} /></h2>
          <p><CopySlot slot="farmers.head.text" copy={sf.copy} /></p>
        </div>

        {farmers.length === 0 && (
          <div style="margin-top:28px">
            <AdminNote text="Фермерите се добавят от админ панела — всеки нов профил се появява автоматично тук." />
          </div>
        )}
        <div class="grid grid--3 grid--farmers" style="margin-top:8px">
          {farmers.length
            ? farmers.map((f) => (
                <FarmerCard farmer={f} productCount={farmerCount(f.id)} categoryCount={farmerCats(f.id)} />
              ))
            : [0, 1, 2].map(() => <GhostFarmerCard />)}
        </div>
      </div>
    </section>

    <section class="section" style="background:var(--surface-2)" data-copy-section="farmers.how">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:34px">
          <span class="eyebrow"><CopySlot slot="farmers.how.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="farmers.how.title" copy={sf.copy} /></h2>
        </div>
        <div class="grid grid--3">
          <div class="card value-card"><div class="ic"><Icon name="heart" /></div><h3><CopySlot slot="farmers.how.s1.title" copy={sf.copy} /></h3><p><CopySlot slot="farmers.how.s1.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="produce" /></div><h3><CopySlot slot="farmers.how.s2.title" copy={sf.copy} /></h3><p><CopySlot slot="farmers.how.s2.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="cart" /></div><h3><CopySlot slot="farmers.how.s3.title" copy={sf.copy} /></h3><p><CopySlot slot="farmers.how.s3.text" copy={sf.copy} /></p></div>
        </div>
      </div>
    </section>
  </main>
</Layout>
