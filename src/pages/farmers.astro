---
import Layout from '../components/Layout.astro';
import CopySlot from '../components/CopySlot.astro';
import Icon from '../components/Icon.astro';
import FarmerCard from '../components/FarmerCard.astro';
import SearchBar from '../components/SearchBar.astro';
import GhostFarmerCard from '../components/GhostFarmerCard.astro';
import AdminNote from '../components/AdminNote.astro';
import { getCatalog } from '../lib/api';
import { catIdOf, categoriesFrom } from '../lib/catalog';
import { itemListLd } from '../lib/jsonld';
import { farmerSlugMap } from '../lib/farmer-slug';
import { resolveMapPoints } from '../lib/farmer-map';
import type { FilterableProduct } from '../lib/farmer-map';

// Browser Google Maps key — read at REQUEST time. On this Cloudflare Workers
// deploy, `Astro.locals.runtime.env` (the Worker's bindings, via
// `platformProxy` in dev too — see astro.config.mjs) is the correct source;
// `globalThis.process?.env` is a legacy Dokploy-container idiom (still used by
// checkout.astro, a known unresolved TODO — see CLOUDFLARE.md #1) that does
// NOT reliably resolve on Workers, which silently disabled this page's map.
// `import.meta.env` covers plain `astro dev` without wrangler. Empty key →
// the Карта tab stays off and „Производители" (card grid) is the only view.
const runtimeBindings = (Astro.locals as any)?.runtime?.env ?? {};
const processEnv = (globalThis as any).process?.env ?? {};
const mapsKey = String(
  runtimeBindings.PUBLIC_GOOGLE_MAPS_KEY ??
    processEnv.PUBLIC_GOOGLE_MAPS_KEY ??
    import.meta.env.PUBLIC_GOOGLE_MAPS_KEY ??
    '',
).trim();

// One /bootstrap round trip (shared memo) instead of separate reads.
const { storefront: sf, farmers, products, subcategories: subcats } = await getCatalog();
const farmerCount = (id: string) => products.filter((p) => p.farmerId === id).length;
const farmerCats = (id: string) =>
  new Set(products.filter((p) => p.farmerId === id).map((p) => catIdOf(p, sf.multiSubcat))).size;
// Collision-safe slug per farmer (see lib/farmer-slug.ts) — shared by every
// link/structured-data reference to a farmer on this page.
const slugs = farmerSlugMap(farmers);
const points = resolveMapPoints(farmers, slugs);
// The Карта tab only makes sense with a working key AND ≥1 geocoded pin —
// otherwise „Производители" (the card grid) is the only view. Also the target
// the client script falls back to if the Maps script fails to load at runtime.
const mapAvailable = mapsKey.length > 0 && points.length > 0;

const active = products.filter((p) => p.isActive !== false);
// Sidebar categories: same taxonomy + live counts as shop.astro, restricted to
// categories that actually have an active product right now.
const cats = categoriesFrom(active, subcats, sf.multiSubcat);
const catCount = new Map<string, number>();
for (const p of active) {
  const k = catIdOf(p, sf.multiSubcat);
  if (k) catCount.set(k, (catCount.get(k) ?? 0) + 1);
}
const kartaCats = cats.filter((c) => (catCount.get(c.id) ?? 0) > 0);

// Filterable products for the client-side matchFarmers() (lib/farmer-map.ts) —
// active catalog only (what shoppers can actually buy); catId is resolved
// server-side here so the client filter never needs to know about multiSubcat.
const filterableProducts: FilterableProduct[] = active.map((p) => ({
  farmerId: p.farmerId,
  name: p.name,
  catId: catIdOf(p, sf.multiSubcat),
}));

// Payload for the map's detail panel (opened by clicking a pin). The card
// grid itself is real server-rendered <FarmerCard> markup below — this trimmed
// JSON is only for the JS-built panel, never used to rebuild the grid.
const farmersPayload = farmers.map((f) => ({
  id: f.id,
  name: f.name,
  role: f.role,
  bio: f.bio,
  city: f.city ?? '',
  imageUrl: f.imageUrl,
  coverCrop: f.coverCrop ?? null,
  slug: slugs.get(f.id) ?? null,
  productCount: farmerCount(f.id),
  // KZP legal identity confirmed → shown as a small ✓ next to the name.
  verified: !!f.legal?.confirmedAt,
}));

// SEO: unique meta description + ItemList of the farmer roster (capped at 50
// inside itemListLd). Omitted entirely when there are no farmers yet.
const farmersMetaDesc = `Запознай се с местните фермери и стопанства зад продуктите на ${sf.name}.`;
const structuredData = farmers.length
  ? itemListLd(farmers.map((f) => ({ name: f.name, path: `/farmer/${slugs.get(f.id)}` })))
  : undefined;
---
<Layout title={`Фермери · ${sf.name}`} description={farmersMetaDesc} storefront={sf} jsonLd={structuredData} pageLabel="Фермери">
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/">Начало</a> / <span>Фермери</span></nav>
    </div>

    <section class="section--tight" data-copy-section="farmers.head">
      <div class="wrap">
        <div class="km-head">
          <div class="section-head" style="max-width:640px;margin:0">
            <span class="eyebrow"><CopySlot slot="farmers.head.eyebrow" copy={sf.copy} /></span>
            <h1 style="margin-top:8px"><CopySlot slot="farmers.head.title" copy={sf.copy} /></h1>
            <p><CopySlot slot="farmers.head.text" copy={sf.copy} /></p>
          </div>
        </div>

        {farmers.length === 0 ? (
          <>
            <div style="margin-top:28px">
              <AdminNote text="Фермерите се добавят от админ панела — всеки нов профил се появява автоматично тук." />
            </div>
            <div class="grid grid--3 grid--farmers" style="margin-top:8px">
              {[0, 1, 2].map(() => <GhostFarmerCard />)}
            </div>
          </>
        ) : (
          <div
            class="km-layout"
            id="kartaExplorer"
            data-maps-key={mapsKey}
            data-map-available={mapAvailable ? '1' : ''}
            data-points={JSON.stringify(points)}
            data-farmers={JSON.stringify(farmersPayload)}
            data-products={JSON.stringify(filterableProducts)}
            data-cats={JSON.stringify(kartaCats.map((c) => ({ id: c.id, name: c.name })))}
          >
            <details class="km-filters card" open>
              <summary class="km-filters__head">Филтри</summary>
              <div class="km-filters__body">
                <SearchBar id="kartaSearch" placeholder="Търси фермер по име, продукт или описание" />

                {kartaCats.length > 0 && (
                  <fieldset class="km-cats">
                    <legend>Категории</legend>
                    {kartaCats.map((c) => (
                      <label class="km-cat">
                        <input type="checkbox" class="km-cat__input" value={c.id} />
                        <span class="km-cat__name">{c.name}</span>
                        <span class="km-cat__count">{catCount.get(c.id) ?? 0}</span>
                      </label>
                    ))}
                  </fieldset>
                )}

                <div class="km-filters__foot">
                  <p class="km-count" id="kartaCount" aria-live="polite">{farmers.length} производители</p>
                  <button type="button" class="km-reset" id="kartaReset" hidden>Изчисти</button>
                </div>
              </div>
            </details>

            <div class="km-main">
              <!-- Роден Дар layout: map on top (when available), the real
                   server-rendered FarmerCard grid always visible below — both
                   driven by the same filters. -->
              <div class="km-map-wrap" hidden id="farmerMapWrap">
                <div id="farmerMap" class="km-map" aria-label="Карта с местоположението на фермерите"></div>
              </div>
              <!-- The client script (scripts/farmer-map.ts) only shows/hides
                   each `[data-farmer-id]` wrapper per the active filter; it
                   never rebuilds these cards. -->
              <div id="farmerGrid" class="grid grid--3 grid--farmers km-grid">
                {farmers.map((f) => (
                  <div class="km-card-entry" data-farmer-id={f.id}>
                    <FarmerCard farmer={f} productCount={farmerCount(f.id)} categoryCount={farmerCats(f.id)} slug={slugs.get(f.id)!} />
                  </div>
                ))}
              </div>
              <p id="kartaEmpty" class="km-empty" hidden>Няма намерени производители за този филтър.</p>
            </div>
          </div>
        )}
      </div>
    </section>

    <script>
      import '../scripts/farmer-map';
    </script>

    <section class="section" style="background:var(--surface-2)" data-copy-section="farmers.how">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:34px">
          <span class="eyebrow"><CopySlot slot="farmers.how.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="farmers.how.title" copy={sf.copy} /></h2>
        </div>
        <div class="grid grid--3">
          <div class="card value-card"><div class="ic"><Icon name="heart" /></div><h3><CopySlot slot="farmers.how.s1.title" copy={sf.copy} /></h3><p><CopySlot slot="farmers.how.s1.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="produce" /></div><h3><CopySlot slot="farmers.how.s2.title" copy={sf.copy} /></h3><p><CopySlot slot="farmers.how.s2.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="cart" /></div><h3><CopySlot slot="farmers.how.s3.title" copy={sf.copy} /></h3><p><CopySlot slot="farmers.how.s3.text" copy={sf.copy} /></p></div>
        </div>
      </div>
    </section>

    <!-- Full-page farmer drawer + backdrop — page-level (fixed), not confined
         to the map box. The client script (farmer-map.ts) toggles both hidden. -->
    <div id="kartaBackdrop" class="km-backdrop" hidden></div>
    <aside id="kartaPanel" class="km-panel" hidden aria-label="Профил на производителя">
      <button type="button" class="km-panel__close" id="kartaPanelClose" aria-label="Затвори">&times;</button>
      <div id="kartaPanelBody" class="km-panel__body"></div>
    </aside>
  </main>

  <!-- is:global: the map + detail panel are built/toggled at runtime by
       scripts/farmer-map.ts — Astro's scoped styles never reach script-touched
       nodes (no data-astro-cid on them), which shipped unstyled once already
       (see commit af7311e). The FarmerCard grid itself keeps its own scoped
       styles from FarmerCard.astro; only the explorer chrome (tabs, sidebar,
       map, panel) lives here. -->
  <style is:global>
    /* The site-wide `.grid { display:grid }` (and any other author `display`)
       outranks the UA stylesheet's `[hidden] { display:none }` — pin these so
       the tab toggle actually hides the inactive view. */
    .km-grid[hidden],
    .km-map-wrap[hidden],
    .km-panel[hidden],
    .km-empty[hidden] {
      display: none !important;
    }

    .km-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 18px;
    }

    .km-layout {
      display: grid;
      grid-template-columns: 340px minmax(0, 1fr);
      gap: 28px;
      margin-top: 26px;
      align-items: start;
    }

    /* ---------- Sidebar (Филтри) ---------- */
    .km-filters { padding: 24px; }
    .km-filters__head {
      font-family: var(--font-head);
      font-weight: var(--h-weight);
      font-size: 21px;
      color: var(--ink);
      cursor: pointer;
      list-style: none;
    }
    .km-filters__head::-webkit-details-marker { display: none; }
    .km-filters__head::before {
      content: '';
      display: inline-block;
      width: 9px; height: 9px;
      margin-right: 9px;
      border-right: 2px solid var(--muted);
      border-bottom: 2px solid var(--muted);
      transform: rotate(45deg);
      transition: transform .18s ease;
      vertical-align: 2px;
    }
    .km-filters[open] > .km-filters__head::before { transform: rotate(-135deg); }
    .km-filters__body { margin-top: 18px; display: flex; flex-direction: column; gap: 18px; }
    .km-filters__body .searchbar { max-width: none; height: 54px; padding: 0 10px 0 16px; }
    .km-filters__body .searchbar__input { font-size: 16.5px; }

    .km-cats { border: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
    .km-cats legend {
      padding: 0 0 8px;
      font-size: 12.5px;
      letter-spacing: var(--label-spacing);
      text-transform: var(--label-transform);
      font-weight: var(--label-weight);
      color: var(--muted);
    }
    .km-cat {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 4px;
      cursor: pointer;
      border-radius: var(--radius-sm);
      min-height: 40px;
    }
    .km-cat:hover { background: var(--surface-2); }
    .km-cat__input { flex: none; width: 19px; height: 19px; accent-color: var(--primary); cursor: pointer; }
    .km-cat__name { flex: 1; font-size: 14.5px; color: var(--ink-soft); }
    .km-cat__count {
      flex: none; min-width: 22px; text-align: center;
      padding: 1px 7px; border-radius: 999px;
      font-size: 11.5px; font-weight: 700;
      background: var(--surface-2); color: var(--muted);
    }

    .km-filters__foot {
      padding-top: 14px;
      border-top: 1px solid var(--line);
      display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap;
    }
    .km-count { font-size: 13px; font-weight: 600; color: var(--muted); margin: 0; }
    .km-reset {
      color: var(--primary); font-size: 13px; font-weight: 700;
      text-decoration: underline; text-underline-offset: 2px;
    }
    .km-reset[hidden] { display: none; }

    /* ---------- Main column (map above, grid below) ---------- */
    .km-main { min-height: 400px; }

    .km-map-wrap { position: relative; margin-bottom: 22px; }
    .km-map-wrap[hidden] { display: none !important; }

    .km-map {
      width: 100%;
      height: 480px;
      border-radius: var(--radius, 18px);
      overflow: hidden;
      border: 1px solid var(--line, #e2dac8);
      background: var(--surface-2, #f6f0e2);
      box-shadow: var(--shadow-sm, 0 2px 8px -3px rgba(44,85,48,.18));
    }

    .km-grid { margin: 0; }
    .km-empty { text-align: center; color: var(--muted); padding: 60px 0; }
    .km-empty[hidden] { display: none; }

    /* ---------- Detail drawer (opened from a map pin) ---------- */
    .km-backdrop {
      position: fixed; inset: 0; z-index: 60;
      background: rgba(20, 30, 18, .32);
      backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
      animation: km-fade .2s ease;
    }
    .km-backdrop[hidden] { display: none !important; }
    @keyframes km-fade { from { opacity: 0; } to { opacity: 1; } }
    @keyframes km-slide { from { transform: translateX(100%); } to { transform: translateX(0); } }
    .km-panel {
      position: fixed;
      top: 0; right: 0; bottom: 0;
      width: 400px;
      max-width: 92vw;
      z-index: 61;
      overflow-y: auto;
      animation: km-slide .22s ease;
      background: var(--surface);
      border-left: 1px solid var(--line);
      border-radius: var(--radius-lg, 22px) 0 0 var(--radius-lg, 22px);
      box-shadow: -16px 0 44px -14px rgba(38,73,47,.4);
    }
    .km-panel[hidden] { display: none !important; }
    .km-panel__close {
      position: sticky; top: 10px; margin: 10px 10px -34px auto;
      float: right;
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; line-height: 1; color: var(--muted);
      background: var(--surface); border: 1px solid var(--line); border-radius: 50%;
      z-index: 1;
    }
    .km-panel__close:hover { color: var(--ink); border-color: var(--primary); }
    .km-panel__body { padding: 22px; display: flex; flex-direction: column; gap: 4px; }
    .km-panel__photo {
      width: 100%; aspect-ratio: 4/5; border-radius: var(--radius-sm);
      overflow: hidden; margin-bottom: 14px;
      display: grid; place-items: center;
      background: var(--primary); color: #fff;
    }
    /* object-position center-top keeps heads in frame; an operator coverCrop
       (inline style) still overrides this when set. */
    .km-panel__photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
    .km-panel__photo .km-card__initials { font-size: 34px; }
    .km-panel__name { display: flex; align-items: center; gap: 8px; font-size: 22px; margin: 0; }
    .km-card__initials { font-family: var(--font-head); font-size: 24px; font-weight: 700; }
    .km-card__check {
      flex: none; display: inline-flex; width: 16px; height: 16px;
      align-items: center; justify-content: center;
      border-radius: 50%; background: var(--primary); color: #fff;
    }
    .km-card__check svg { width: 10px; height: 10px; }
    .km-panel__role { font-size: 13.5px; color: var(--muted); font-weight: 600; margin-top: 2px; }
    .km-panel__city {
      display: inline-flex; align-items: center; gap: 6px;
      margin-top: 10px; font-size: 13.5px; color: var(--muted);
    }
    .km-panel__city svg { width: 15px; height: 15px; flex: none; }
    .km-panel__bio {
      margin-top: 12px; font-size: 14.5px; color: var(--ink-soft); line-height: 1.55;
      display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 6; overflow: hidden;
    }
    .km-panel__chips { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 14px; }
    .km-panel__chip {
      padding: 4px 11px; border-radius: 999px; font-size: 12px; font-weight: 600;
      background: var(--primary-050); color: var(--primary);
    }
    .km-panel .btn { margin-top: 20px; width: 100%; }

    /* ---------- Mobile ---------- */
    @media (max-width: 880px) {
      .km-layout { grid-template-columns: 1fr; gap: 16px; }
      .km-filters__head { pointer-events: auto; }
      .km-main { min-height: 460px; }
      .km-map { min-height: 460px; }

      .km-panel {
        position: fixed;
        top: auto; left: 0; right: 0; bottom: 0;
        width: auto; max-width: none;
        max-height: 60vh;
        border-radius: var(--radius-lg, 26px) var(--radius-lg, 26px) 0 0;
        box-shadow: 0 -10px 30px -12px rgba(0, 0, 0, .35);
      }
    }

    @media (min-width: 881px) {
      /* Desktop: the sidebar is always expanded — the disclosure affordance is
         mobile-only (see farmer-map.ts, which force-opens it above this width). */
      .km-filters__head { cursor: default; pointer-events: none; }
      .km-filters__head::before { display: none; }
    }
  </style>
</Layout>
