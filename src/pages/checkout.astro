---
import Layout from '../components/Layout.astro';
import { getStorefront, FALLBACK_STOREFRONT } from '../lib/api';
import { ONLY_LOCAL_DELIVERY } from '../lib/config';
import { bgnText } from '../lib/currency';
const sf = (await getStorefront()) ?? FALLBACK_STOREFRONT;
const delivery = sf.deliveryEnabled;
const econt = sf.econtEnabled;
const econtAuto = sf.econtMode === 'auto';
const speedyConfigured = sf.speedyConfigured ?? false;

// Payment options, mirroring the admin panel. Card (online) shows only when the
// farm has Stripe; наложен платеж (COD) only when enabled. Show the radio choice
// when both are available; otherwise the single available option is implied.
const codEnabled = sf.codEnabled ?? true;
const stripeEnabled = sf.stripeEnabled ?? false;
const showPaymentChoice = stripeEnabled && codEnabled;

// Per-method on/off flags — show only the methods the farm switched on.
const methods = sf.methods ?? { ownSlots: true, pickup: true, econtOffice: false, econtAddress: false };
// Door (до адрес) delivery is offered when Econt-address is on OR Speedy is
// configured — mirrors the backend courierDoorEnabled()/assertMethodAllowed
// so a Speedy-only farm (Econt off) still gets the storefront card.
const doorDelivery = (econt && methods.econtAddress) || speedyConfigured;

// ONLY_LOCAL_DELIVERY (see ../lib/config): заключваме всичко освен ЛИЧНАТА (местна)
// доставка до адрес, за да не приема поръчки, които не можем да изпълним. Куриер →
// показва се заключен с „временно не работи"; вземане на място → само информация,
// не checkout опция; Еконт → скрит.

// Delivery pricing from the farm's config (cents). The client script reads the
// data-* on the form; these strings drive the method-card copy.
const d = sf.delivery;
const eur = (st: number) => (st / 100).toFixed(2).replace('.', ',');
const lvNum = (st: number) => (st / 100).toString();
const freeOverTxt = d.freeThresholdStotinki > 0 ? ` · безплатна над ${eur(d.freeThresholdStotinki)} €${bgnText(d.freeThresholdStotinki / 100)}` : '';
const addrFeeTxt = d.addressFeeStotinki > 0 ? `${eur(d.addressFeeStotinki)} €${bgnText(d.addressFeeStotinki / 100)}` : 'безплатна';

const ownSlots = sf.ownSlots;
const ownSlotsSchedule = ownSlots?.schedule ? `${ownSlots.schedule} · ` : '';

const pickup = sf.pickup;
// Bulgarian grammatical gender varies by weekday ("Всеки понеделник" vs "Всяка
// сряда") — spell out each phrase rather than trying to conjugate generically.
const WD_NAMES = [
  'Всяка неделя', 'Всеки понеделник', 'Всеки вторник', 'Всяка сряда',
  'Всеки четвъртък', 'Всеки петък', 'Всяка събота',
];
const pickupLabel = pickup?.label || 'Вземане от място';
const pickupSchedule =
  pickup && pickup.weekday != null && pickup.timeFrom && pickup.timeTo
    ? `${WD_NAMES[pickup.weekday]} · ${pickup.timeFrom}–${pickup.timeTo}`
    : pickup?.hours || null;
const pickupSubtitle = [pickupSchedule, 'без такса', 'плащаш на място'].filter(Boolean).join(' · ');

// Browser Google Maps key for checkout address autocomplete. Read at REQUEST
// time from the container's runtime env (set in Dokploy) — NOT a build-time
// import.meta.env constant, because the prod image is built in CI before Dokploy
// runs it, so only a runtime read sees the Dokploy-provided value. Falls back to
// import.meta.env for local `astro dev` (.env). Empty → autocomplete stays off
// and checkout uses the plain inputs (the backend geocodes the typed address).
const runtimeEnv = (globalThis as any).process?.env ?? {};
const mapsKey = String(
  runtimeEnv.PUBLIC_GOOGLE_MAPS_KEY ?? import.meta.env.PUBLIC_GOOGLE_MAPS_KEY ?? '',
).trim();
---
<Layout title={`Каса · ${sf.name}`} storefront={sf} noindex pageLabel="Плащане">
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/cart">Количка</a> / <span>Каса</span></nav>
    </div>

    <section class="section--tight">
      <div class="wrap">
        <div class="steps">
          <span class="step done"><span class="num">1</span>Количка</span><span class="sep"></span>
          <span class="step current"><span class="num">2</span>Доставка и плащане</span><span class="sep"></span>
          <span class="step"><span class="num">3</span>Готово</span>
        </div>
        <h1 style="font-size:clamp(28px,4vw,42px);margin:14px 0 24px">Финализирай поръчката</h1>

        <form class="commerce-grid" id="checkoutForm" data-delivery={delivery ? '1' : '0'}
          data-econt-mode={sf.econtMode}
          data-stripe={stripeEnabled ? '1' : '0'}
          data-cod={codEnabled ? '1' : '0'}
          data-free-over={lvNum(d.freeThresholdStotinki)}
          data-ship-address={lvNum(d.addressFeeStotinki)}
          data-ship-econt={lvNum(d.econtFeeStotinki)}
          data-ship-econt-address={lvNum(d.econtAddressFeeStotinki)}
          data-comparison={sf.comparisonActive ? '1' : '0'}
          data-carrier-policy={sf.carrierPolicy ?? 'customer'}
          data-maps-key={mapsKey}
          data-pickup-label={pickupLabel}
          data-pickup-address={pickup?.address ?? ''}>
          <div class="stack" style="gap:26px">

            <!-- contact -->
            <div class="card co-card">
              <h3 style="font-size:20px;margin-bottom:16px">Контакти</h3>
              <div class="stack" style="gap:14px">
                <div class="field"><label>Име и фамилия</label><input class="input" name="customerName" autocomplete="name" placeholder="Иван Иванов" required /></div>
                <div class="field-row">
                  <div class="field"><label>Телефон</label><input class="input" name="customerPhone" type="tel" autocomplete="tel" placeholder="+359 88 ..." required /></div>
                  <div class="field"><label>Имейл <span class="muted" style="font-weight:400">(по желание — за потвърждение)</span></label><input class="input" name="customerEmail" type="email" autocomplete="email" placeholder="ime@example.bg" /></div>
                </div>
              </div>
            </div>

            <!-- delivery method -->
            <div class="card co-card">
              <h3 style="font-size:20px;margin-bottom:16px">Начин на получаване</h3>
              <div class="stack" style="gap:12px" id="deliveryMethod">
                {((delivery && methods.ownSlots) || ONLY_LOCAL_DELIVERY) && (
                  <label class="radio-card" data-method="address">
                    <span class="dot"></span>
                    <span><b>Местна доставка до адрес</b><br><span class="muted" style="font-size:14px">Доставка от фермата · {ownSlotsSchedule}{addrFeeTxt}{d.addressFeeStotinki > 0 ? freeOverTxt : ''}</span><br><span class="muted" style="font-size:13px">само за Варна, Добрич и околностите</span></span>
                  </label>
                )}
                {!ONLY_LOCAL_DELIVERY && econt && econtAuto && methods.econtOffice && (
                  <label class="radio-card" data-method="econt">
                    <span class="dot"></span>
                    <span><b>Еконт — до офис</b><br><span class="muted" style="font-size:14px">До офис на Еконт в цялата страна · от {eur(d.econtFeeStotinki)} €{bgnText(d.econtFeeStotinki / 100)}</span></span>
                  </label>
                )}
                {!ONLY_LOCAL_DELIVERY && doorDelivery && (
                  <label class="radio-card" data-method="econt_address">
                    <span class="dot"></span>
                    <span><b>Доставка до адрес</b><br><span class="muted" style="font-size:14px">Даваш адрес · куриерът доставя до теб · от {eur(d.econtAddressFeeStotinki)} €{bgnText(d.econtAddressFeeStotinki / 100)}</span></span>
                  </label>
                )}
                {methods.pickup && (
                  <label class="radio-card" data-method="pickup">
                    <span class="dot"></span>
                    <span>
                      <b>{pickupLabel}</b><br>
                      <span class="muted" style="font-size:14px">{pickupSubtitle}</span>
                      {pickup?.address && <br />}
                      {pickup?.address && <span class="muted" style="font-size:13px">{pickup.address}</span>}
                    </span>
                  </label>
                )}
              </div>

              <!-- Куриер: временно изключен (виж ONLY_LOCAL_DELIVERY горе). Плоска
                   информационна бележка, НЕ радио-карта — иначе изглежда като
                   избираема, но „развалена“ опция и обърква купувача. -->
              <div data-courier-locked style="margin-top:14px;padding:12px 14px;border:1px dashed var(--line);border-radius:12px;background:var(--surface-2)">
                <div style="font-weight:700;margin-bottom:2px">Куриер до цялата страна — временно не работи</div>
                <span class="muted" style="font-size:14px">Работим по него. За сега е достъпна само местната доставка или вземане от пазара (виж горе).</span>
              </div>

              <!-- delivery address (local delivery + Econt-to-address). One field
                   with Google Places autocomplete: the customer types and picks a
                   real address, so the order carries exact coords and the backend
                   skips geocoding. A hand-typed address still submits (backend
                   geocodes it). Second field captures block/entrance/floor/flat,
                   which Places does not return. -->
              <div id="addressFields" style="margin-top:14px;display:none">
                <div class="field">
                  <label>Адрес *</label>
                  <input class="input" id="addressInput" placeholder="Започни да пишеш улица и град…" autocomplete="off" />
                  <span class="muted" id="addrHint" style="font-size:14px;display:block;margin-top:6px">Улица и номер + град (напр. ул. Дунав 5, Варна). Избери от предложенията, ако се появят.</span>
                </div>
                <div class="field" style="margin-top:10px">
                  <label>Блок, вход, етаж, апартамент <span class="muted">(по желание)</span></label>
                  <input class="input" id="addrDetails" placeholder="напр. бл. 12, вх. А, ет. 3, ап. 9" autocomplete="off" />
                  <span class="muted" style="font-size:14px;display:block;margin-top:6px">Само вход/блок/етаж — <b>не</b> улицата. Улицата и номерът се пишат в „Адрес“ по-горе.</span>
                </div>
              </div>

              <!-- Carrier picker (Econt vs Speedy) — shown for door delivery only
                   when the farm runs both carriers (comparisonActive). Populated
                   client-side from POST /shipping/compare once a city is known. In
                   'customer' policy the buyer picks; otherwise it's a read-only note. -->
              <div id="carrierPicker" style="margin-top:14px;display:none">
                <label style="display:block;font-size:14px;font-weight:600;margin-bottom:8px">Куриер</label>
                <div class="stack" style="gap:12px" id="carrierOptions"></div>
                <span class="muted" id="carrierHint" style="font-size:13px;display:block;margin-top:8px"></span>
              </div>

              <!-- Econt office (auto: live picker · manual: free-text) -->
              <div id="econtOfficeFields" style="margin-top:14px;display:none">
                <div class="field"><label>Град</label><input class="input" id="econtCity" placeholder="напр. София, Пловдив, Варна" autocomplete="off" /></div>
                <div class="field" style="margin-top:10px">
                  <label>Офис на Еконт</label>
                  {econtAuto ? (
                    <select class="input" id="econtOffice"><option value="">Първо въведи град</option></select>
                  ) : (
                    <input class="input" id="econtOffice" placeholder="напр. Еконт офис Чайка, ул. ..." autocomplete="off" />
                  )}
                </div>
              </div>
            </div>

            {delivery && (
              <!-- delivery slot -->
              <div class="card co-card" id="slotCard" style="display:none">
                <h3 style="font-size:20px;margin-bottom:6px">Кога да доставим?</h3>
                <p class="muted" style="font-size:14px;margin-bottom:4px">Първо избери ден, после свободен час. Показваме само часовете със свободни места.</p>
                <div class="slot-step"><span class="n">1</span>Избери ден</div>
                <div class="date-pills" id="datePills"></div>
                <div class="slot-step" id="slotStep2" style="display:none"><span class="n">2</span>Избери час</div>
                <div class="slots" id="slots"></div>
                <div id="slotChosen" class="note-fresh" style="margin-top:16px;display:none"></div>
              </div>
            )}

            <!-- payment method (mirrors the admin panel: card when Stripe, наложен платеж when enabled) -->
            <div class="card co-card">
              <h3 style="font-size:20px;margin-bottom:16px">Начин на плащане</h3>
              {showPaymentChoice ? (
                <div class="stack" style="gap:12px" id="paymentMethod">
                  <label class="radio-card is-active" data-pay="online">
                    <span class="dot"></span>
                    <span><b>Карта (онлайн)</b><br><span class="muted" style="font-size:14px">Плащаш сигурно с карта сега</span></span>
                  </label>
                  <label class="radio-card" data-pay="cod">
                    <span class="dot"></span>
                    <span><b>Наложен платеж</b><br><span class="muted" style="font-size:14px">Плащаш при получаване{econt ? ' (напр. в офис на Еконт)' : ''}</span></span>
                  </label>
                </div>
              ) : (
                <p class="muted" style="font-size:14px">
                  {stripeEnabled
                    ? 'Плащане с карта (онлайн) при завършване на поръчката.'
                    : 'Плащане при получаване (наложен платеж).'}
                </p>
              )}
            </div>

          </div>

          <!-- summary -->
          <aside class="summary">
            <h3 style="font-size:22px;margin-bottom:14px">Твоята поръчка</h3>
            <div id="orderLines"></div>
            <div id="orderTotals"></div>
            <label id="termsCheck" style="display:flex;gap:10px;align-items:flex-start;font-size:14px;line-height:1.5;margin-top:16px;padding:8px 2px;cursor:pointer">
              <input type="checkbox" required style="margin-top:1px;flex:none;width:20px;height:20px" />
              <span>Прочетох и приемам <a href="/terms" target="_blank" rel="noopener" style="color:var(--primary);text-decoration:underline">Общите условия</a> и <a href="/privacy" target="_blank" rel="noopener" style="color:var(--primary);text-decoration:underline">Политиката за поверителност</a>.</span>
            </label>
            <button class="btn btn--primary btn--full btn--lg" type="submit" id="placeOrder" style="margin-top:14px;line-height:1.3">
              Поръчай сега<br /><span style="font-size:12px;font-weight:500;opacity:.85">поръчка със задължение за плащане</span>
            </button>
          </aside>

          <!-- Mobile sticky submit bar (≤880px, see main.css .co-mobilebar) — proxies
               the real submit button so every guard/validation/Stripe path stays the
               single source of truth; only visually surfaces the total + CTA. -->
          <div class="co-mobilebar" id="mobileOrderBar">
            <div class="co-mobilebar__total"><span class="muted">Общо</span><b id="mobileBarTotal">—</b></div>
            <button type="button" class="btn btn--primary btn--lg" id="mobileOrderBtn">Поръчай</button>
          </div>
        </form>
      </div>
    </section>
  </main>
  <script>
    import '../scripts/checkout-page.ts';
  </script>
</Layout>
