---
import Layout from '../components/Layout.astro';
import { getStorefront, FALLBACK_STOREFRONT } from '../lib/api';
const sf = (await getStorefront()) ?? FALLBACK_STOREFRONT;
const delivery = sf.deliveryEnabled;
const econt = sf.econtEnabled;
const econtAuto = sf.econtMode === 'auto';

// Payment options, mirroring the admin panel. Card (online) shows only when the
// farm has Stripe; наложен платеж (COD) only when enabled. Show the radio choice
// when both are available; otherwise the single available option is implied.
const codEnabled = sf.codEnabled ?? true;
const stripeEnabled = sf.stripeEnabled ?? false;
const showPaymentChoice = stripeEnabled && codEnabled;

// Per-method on/off flags — show only the methods the farm switched on.
const methods = sf.methods ?? { ownSlots: true, pickup: true, econtOffice: false, econtAddress: false };

// Delivery pricing from the farm's config (cents). The client script reads the
// data-* on the form; these strings drive the method-card copy.
const d = sf.delivery;
const eur = (st: number) => (st / 100).toFixed(2).replace('.', ',');
const lvNum = (st: number) => (st / 100).toString();
const freeOverTxt = d.freeThresholdStotinki > 0 ? ` · безплатна над ${eur(d.freeThresholdStotinki)} €` : '';
const addrFeeTxt = d.addressFeeStotinki > 0 ? `${eur(d.addressFeeStotinki)} €` : 'безплатна';
---
<Layout title={`Каса · ${sf.name}`} storefront={sf}>
  <main>
    <div class="wrap">
      <nav class="breadcrumb"><a href="/cart">Количка</a> / <span>Каса</span></nav>
    </div>

    <section class="section--tight">
      <div class="wrap">
        <div class="steps">
          <span class="step done"><span class="num">1</span>Количка</span><span class="sep"></span>
          <span class="step current"><span class="num">2</span>Доставка и плащане</span><span class="sep"></span>
          <span class="step"><span class="num">3</span>Готово</span>
        </div>
        <h1 style="font-size:clamp(28px,4vw,42px);margin:14px 0 24px">Финализирай поръчката</h1>

        <form class="commerce-grid" id="checkoutForm" data-delivery={delivery ? '1' : '0'}
          data-econt-mode={sf.econtMode}
          data-stripe={stripeEnabled ? '1' : '0'}
          data-cod={codEnabled ? '1' : '0'}
          data-free-over={lvNum(d.freeThresholdStotinki)}
          data-ship-address={lvNum(d.addressFeeStotinki)}
          data-ship-econt={lvNum(d.econtFeeStotinki)}
          data-ship-econt-address={lvNum(d.econtAddressFeeStotinki)}>
          <div class="stack" style="gap:26px">

            <!-- contact -->
            <div class="card" style="padding:24px;box-shadow:none">
              <h3 style="font-size:20px;margin-bottom:16px">Контакти</h3>
              <div class="stack" style="gap:14px">
                <div class="field"><label>Име и фамилия</label><input class="input" name="customerName" placeholder="Иван Иванов" required /></div>
                <div class="field-row">
                  <div class="field"><label>Телефон</label><input class="input" name="customerPhone" type="tel" placeholder="+359 88 ..." required /></div>
                  <div class="field"><label>Имейл</label><input class="input" name="customerEmail" type="email" placeholder="ime@example.bg" required /></div>
                </div>
              </div>
            </div>

            <!-- delivery method -->
            <div class="card" style="padding:24px;box-shadow:none">
              <h3 style="font-size:20px;margin-bottom:16px">Начин на получаване</h3>
              <div class="stack" style="gap:12px" id="deliveryMethod">
                {methods.pickup && (
                  <label class="radio-card" data-method="pickup">
                    <span class="dot"></span>
                    <span><b>Вземане от пазара · Чайка</b><br><span class="muted" style="font-size:14px">В петък 11:00–18:00 · без такса · плащаш на място</span></span>
                  </label>
                )}
                {delivery && methods.ownSlots && (
                  <label class="radio-card" data-method="address">
                    <span class="dot"></span>
                    <span><b>Местна доставка до адрес</b><br><span class="muted" style="font-size:14px">Доставка от фермата · петък 11:00–20:00 · {addrFeeTxt}{d.addressFeeStotinki > 0 ? freeOverTxt : ''}</span></span>
                  </label>
                )}
                {econt && econtAuto && methods.econtOffice && (
                  <label class="radio-card" data-method="econt">
                    <span class="dot"></span>
                    <span><b>Еконт — до офис</b><br><span class="muted" style="font-size:14px">До офис на Еконт в цялата страна · от {eur(d.econtFeeStotinki)} €</span></span>
                  </label>
                )}
                {econt && methods.econtAddress && (
                  <label class="radio-card" data-method="econt_address">
                    <span class="dot"></span>
                    <span><b>Доставка с Еконт</b><br><span class="muted" style="font-size:14px">Даваш адрес · Еконт носи до най-близкия офис до теб · от {eur(d.econtAddressFeeStotinki)} €</span></span>
                  </label>
                )}
              </div>

              <!-- street address (local delivery + Econt-to-address) -->
              <div id="addressFields" style="margin-top:14px;display:none">
                <div id="doorCityField" class="field" style="display:none">
                  <label>Град / населено място</label>
                  <input class="input" id="doorCity" placeholder="напр. Бургас, Пловдив, София" autocomplete="off" />
                </div>
                <div class="field" style="margin-top:10px">
                  <label id="addressLabel">Адрес за доставка</label>
                  <input class="input" id="addressInput" placeholder="ул., №, град, пощенски код" />
                </div>
              </div>

              <!-- Econt office (auto: live picker · manual: free-text) -->
              <div id="econtOfficeFields" style="margin-top:14px;display:none">
                <div class="field"><label>Град</label><input class="input" id="econtCity" placeholder="напр. София, Пловдив, Варна" autocomplete="off" /></div>
                <div class="field" style="margin-top:10px">
                  <label>Офис на Еконт</label>
                  {econtAuto ? (
                    <select class="input" id="econtOffice"><option value="">Първо въведи град</option></select>
                  ) : (
                    <input class="input" id="econtOffice" placeholder="напр. Еконт офис Чайка, ул. ..." autocomplete="off" />
                  )}
                </div>
              </div>
            </div>

            {delivery && (
              <!-- delivery slot -->
              <div class="card" id="slotCard" style="padding:24px;box-shadow:none;display:none">
                <h3 style="font-size:20px;margin-bottom:6px">Часови слот за доставка</h3>
                <p class="muted" style="font-size:14px;margin-bottom:16px">Избери удобен ден и час. Заетите слотове са недостъпни.</p>
                <div class="date-pills" id="datePills"></div>
                <div class="slots" id="slots" style="margin-top:16px"></div>
                <div id="slotChosen" class="note-fresh" style="margin-top:16px;display:none"></div>
              </div>
            )}

            <!-- payment method (mirrors the admin panel: card when Stripe, наложен платеж when enabled) -->
            <div class="card" style="padding:24px;box-shadow:none">
              <h3 style="font-size:20px;margin-bottom:16px">Начин на плащане</h3>
              {showPaymentChoice ? (
                <div class="stack" style="gap:12px" id="paymentMethod">
                  <label class="radio-card is-active" data-pay="online">
                    <span class="dot"></span>
                    <span><b>Карта (онлайн)</b><br><span class="muted" style="font-size:14px">Плащаш сигурно с карта сега</span></span>
                  </label>
                  <label class="radio-card" data-pay="cod">
                    <span class="dot"></span>
                    <span><b>Наложен платеж</b><br><span class="muted" style="font-size:14px">Плащаш при получаване (напр. в офис на Еконт)</span></span>
                  </label>
                </div>
              ) : (
                <p class="muted" style="font-size:14px">
                  {stripeEnabled
                    ? 'Плащане с карта (онлайн) при завършване на поръчката.'
                    : 'Плащане при получаване (наложен платеж).'}
                </p>
              )}
            </div>

          </div>

          <!-- summary -->
          <aside class="summary">
            <h3 style="font-size:22px;margin-bottom:14px">Твоята поръчка</h3>
            <div id="orderLines"></div>
            <div id="orderTotals"></div>
            <button class="btn btn--primary btn--full btn--lg" type="submit" id="placeOrder" style="margin-top:16px">Завърши поръчката</button>
            <p class="muted center" style="font-size:12.5px;margin-top:10px">С натискане приемаш Общите условия</p>
          </aside>
        </form>
      </div>
    </section>
  </main>
  <script>
    import '../scripts/checkout-page.ts';
  </script>
</Layout>
