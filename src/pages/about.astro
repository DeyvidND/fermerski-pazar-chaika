---
import Layout from '../components/Layout.astro';
import Icon from '../components/Icon.astro';
import MediaSlot from '../components/MediaSlot.astro';
import CopySlot from '../components/CopySlot.astro';
import { getStorefront, FALLBACK_STOREFRONT } from '../lib/api';
const sf = (await getStorefront()) ?? FALLBACK_STOREFRONT;
const showFarmers = sf.multiFarmer;
---
<Layout title={`За нас · ${sf.name}`} storefront={sf} pageLabel="За нас">
  <main>
    <section class="section" data-copy-section="about.hero">
      <div class="wrap split">
        <div>
          <span class="eyebrow"><CopySlot slot="about.hero.eyebrow" copy={sf.copy} /></span>
          <h1 style="font-size:clamp(36px,5.5vw,60px);margin:12px 0 18px"><CopySlot slot="about.hero.title" copy={sf.copy} /></h1>
          <p class="lead">{sf.name} <CopySlot slot="about.hero.lead" copy={sf.copy} /></p>
          <div class="cta-row">
            <a href={showFarmers ? '/farmers' : '/shop'} class="btn btn--primary">{showFarmers ? 'Виж фермерите' : 'Към магазина'}</a>
            <a href="/orders" class="btn btn--ghost">Как да поръчам</a>
          </div>
        </div>
        <MediaSlot slot="about.portrait" media={sf.media} />
      </div>
    </section>

    <section class="section--tight" data-copy-section="about.story">
      <div class="wrap prose">
        <p><CopySlot slot="about.story.p1" copy={sf.copy} /></p>
        <p><CopySlot slot="about.story.p2" copy={sf.copy} /></p>
        <p><CopySlot slot="about.story.p3" copy={sf.copy} /></p>
      </div>
    </section>

    <section class="section" style="background:var(--surface-2)" data-copy-section="about.values">
      <div class="wrap">
        <div class="section-head center" style="margin-bottom:36px">
          <span class="eyebrow"><CopySlot slot="about.values.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="about.values.title" copy={sf.copy} /></h2>
        </div>
        <div class="grid grid--4">
          <div class="card value-card"><div class="ic"><Icon name="leaf" /></div><h3><CopySlot slot="about.values.1.title" copy={sf.copy} /></h3><p><CopySlot slot="about.values.1.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="basket" /></div><h3><CopySlot slot="about.values.2.title" copy={sf.copy} /></h3><p><CopySlot slot="about.values.2.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="heart" /></div><h3><CopySlot slot="about.values.3.title" copy={sf.copy} /></h3><p><CopySlot slot="about.values.3.text" copy={sf.copy} /></p></div>
          <div class="card value-card"><div class="ic"><Icon name="check" /></div><h3><CopySlot slot="about.values.4.title" copy={sf.copy} /></h3><p><CopySlot slot="about.values.4.text" copy={sf.copy} /></p></div>
        </div>
      </div>
    </section>

    <section class="section" data-copy-section="about.gallery">
      <div class="wrap">
        <div class="section-head" style="margin-bottom:28px">
          <span class="eyebrow"><CopySlot slot="about.gallery.eyebrow" copy={sf.copy} /></span>
          <h2 style="margin-top:8px"><CopySlot slot="about.gallery.title" copy={sf.copy} /></h2>
        </div>
        <div class="gallery">
          <MediaSlot slot="about.gallery_stalls" media={sf.media} klass="wide" />
          <MediaSlot slot="about.gallery_basket" media={sf.media} />
          <MediaSlot slot="about.gallery_honey" media={sf.media} klass="tall" />
          <MediaSlot slot="about.gallery_dairy" media={sf.media} />
          <MediaSlot slot="about.gallery_farmer" media={sf.media} />
          <MediaSlot slot="about.gallery_sweets" media={sf.media} />
          <MediaSlot slot="about.gallery_customers" media={sf.media} />
        </div>
      </div>
    </section>

    <section class="section--tight" data-copy-section="about.quote">
      <div class="wrap center">
        <p class="quote" style="margin-inline:auto"><CopySlot slot="about.quote" copy={sf.copy} /></p>
        <div style="margin-top:22px;font-weight:600">— екипът на {sf.name}</div>
      </div>
    </section>
  </main>
</Layout>
