---
// Skeleton farmer card shown while no farmers are seeded yet.
---
<article class="card farmer-card is-ghost" aria-hidden="true">
  <div class="ph farmer-card__photo"><span class="ph__label">фермер</span></div>
  <div class="farmer-card__body">
    <span class="sk sk--eyebrow"></span>
    <span class="sk sk--title" style="margin-top:8px"></span>
    <span class="sk sk--text" style="margin-top:10px"></span>
    <span class="sk sk--text" style="width:90%"></span>
    <span class="sk sk--text" style="width:70%"></span>
    <div class="farmer-card__foot">
      <span class="sk sk--chip"></span>
      <span class="sk sk--btn"></span>
    </div>
  </div>
</article>
