---
import '../styles/theme.css';
import '../styles/main.css';
import '../styles/home.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import TrackingScripts from './TrackingScripts.astro';
import ConsentBanner from './ConsentBanner.astro';
import { getStorefront, getCatalog, FALLBACK_STOREFRONT } from '../lib/api';
import { safeHref } from '../lib/site';
import { SITE_URL } from '../lib/config';
import { IMG_ORIGIN } from '../lib/img';
import { websiteLd, localBusinessLd } from '../lib/jsonld';
import JsonLd from './JsonLd.astro';
import { resolveSlot } from '../lib/editable-manifest';
import type { Storefront } from '../lib/types';

interface Props {
  title: string;
  description?: string;
  storefront?: Storefront;
  bodyClass?: string;
  /** Origin of the image host (R2/CDN). Emitted as preconnect so the first
   *  photo's connection is warm before the browser reaches the <img>. */
  imageOrigin?: string | null;
  /** Absolute image URL for og:image / Twitter card (page hero/cover). Omitted →
   *  a text-only summary card. */
  image?: string | null;
  /** Extra schema.org JSON-LD node(s) for this page (Product, Article, breadcrumb).
   *  The sitewide WebSite + LocalBusiness nodes are always emitted. */
  jsonLd?: unknown | unknown[];
  /** Keep this page out of the search index (transactional / private pages, 404).
   *  Emits <meta name="robots" content="noindex, follow">. */
  noindex?: boolean;
  /** Human label for the page_view analytics beacon (e.g. "Продукт", "Фермери")
   *  — shows up in the farmer's "Топ страници" panel instead of a raw URL.
   *  Omit for pages that shouldn't count toward that list (404 etc.) — the
   *  backend then falls back to a best-effort path guess. */
  pageLabel?: string;
}

const { title, description, bodyClass, imageOrigin, image, jsonLd, noindex, pageLabel } = Astro.props;
// Reuse the profile a data-heavy page already fetched; otherwise fetch it here.
const storefront: Storefront =
  Astro.props.storefront ?? (await getStorefront()) ?? FALLBACK_STOREFRONT;

// «Продукт на седмицата» as a thin top bar (admin placement = 'bar'). It's
// site-wide, so it lives in the Layout rather than per page. Only fetch the
// catalog when the bar is actually on; getCatalog is memoised, so pages that
// already loaded it pay nothing. `productOfWeek` is null when the highlight is off.
let potwBar: { name: string; href: string } | null = null;
if (storefront.productOfWeekPlacement === 'bar') {
  const boot = await getCatalog();
  const info = boot?.productOfWeek ?? null;
  const p = info ? boot.products.find((x) => x.id === info.id) ?? null : null;
  if (p) potwBar = { name: p.name, href: p.slug ? `/product/${p.slug}` : '/shop' };
}

// Falls back to the actual homepage hero copy (owner-editable via the admin
// panel's «Промени сайта») instead of a second hand-written string that
// silently drifts out of sync with it — that's what link-preview cards
// (Telegram/FB/Viber) end up showing for months after the page copy changes.
const desc = description ?? resolveSlot(storefront.copy, 'home.hero.lead');

const favicon = storefront.faviconUrl || '/favicon.svg';
const faviconPath = favicon.split(/[?#]/)[0].toLowerCase();
const faviconType = faviconPath.endsWith('.svg')
  ? 'image/svg+xml'
  : faviconPath.endsWith('.png')
    ? 'image/png'
    : faviconPath.endsWith('.ico')
      ? 'image/x-icon'
      : undefined;
const themeColor = storefront.themeColor || '#3F7D43';

// Canonical URL: fixed customer domain + clean path (drops query/tracking params),
// so filtered/edit-token variants and the Workers preview host don't fragment
// indexing across duplicate URLs.
const canonical = `${SITE_URL}${Astro.url.pathname}`;
---
<!DOCTYPE html>
<html lang="bg" data-theme="ferma">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={desc} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title={`${storefront.name} · Статии`} href={`${SITE_URL}/rss.xml`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={storefront.name} />
  <meta property="og:locale" content="bg_BG" />
  {image && <meta property="og:image" content={image} />}
  <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={desc} />
  {image && <meta name="twitter:image" content={image} />}
  <JsonLd data={[websiteLd(storefront), localBusinessLd(storefront), ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])]} />
  <meta name="theme-color" content={themeColor} />
  <link rel="icon" href={safeHref(favicon)} type={faviconType} />
  {(IMG_ORIGIN ?? imageOrigin) && (
    <>
      <link rel="preconnect" href={IMG_ORIGIN ?? imageOrigin} crossorigin />
      <link rel="dns-prefetch" href={IMG_ORIGIN ?? imageOrigin} />
    </>
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {/* Non-render-blocking font load: preload as style, then promote to stylesheet. */}
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Commissioner:wght@300;400;500;600;700&family=Onest:wght@400;500;600;700;800&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Commissioner:wght@300;400;500;600;700&family=Onest:wght@400;500;600;700;800&display=swap"
    />
  </noscript>
  <TrackingScripts storefront={storefront} />
</head>
<body class={bodyClass} data-page-label={pageLabel}>
  {potwBar && (
    <a class="potw-bar" href={potwBar.href}>
      <span class="potw-bar__inner">
        <span class="potw-bar__star" aria-hidden="true">★</span>
        <span class="potw-bar__label">Продукт на седмицата:</span>
        <span class="potw-bar__name">{potwBar.name}</span>
        <span class="potw-bar__arrow" aria-hidden="true">→</span>
      </span>
    </a>
  )}
  <Header storefront={storefront} />
  <slot />
  <Footer storefront={storefront} />
  <ConsentBanner storefront={storefront} />
  <script>
    import '../scripts/ui.ts';
    // The edit overlay loads lazily, only in edit mode. It MUST be a runtime
    // dynamic import inside this single always-on script: a conditionally
    // *rendered* `<script>` ({isEdit && <script>…}) is still statically hoisted
    // by Astro regardless of the condition, and that collided with bundling so
    // the always-on ui.ts chunk was dropped from normal pages — add-to-cart
    // (and every other ui.ts handler) silently died. One hoisted script keeps
    // ui.ts on every page and gates the overlay correctly.
    if (new URLSearchParams(window.location.search).has('edit')) {
      import('../scripts/edit-overlay.ts');
    }
  </script>
  <script>
    import { ffTrack } from '../lib/track';
    // Read from the DOM rather than closing over an Astro frontmatter var: this
    // script is hoisted/bundled once and shared across every page (see the
    // ui.ts hoisting note above), so it can't have a per-page value baked in —
    // document.body.dataset is always populated by the time any script runs.
    const pageLabel = document.body.dataset.pageLabel || undefined;
    ffTrack('page_view', pageLabel ? { pageLabel } : {});
  </script>
</body>
</html>

<style>
  .potw-bar {
    display: block;
    background: var(--primary);
    color: #fff;
    text-decoration: none;
  }
  .potw-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 9px 16px;
    font-size: 14px;
    line-height: 1.2;
  }
  .potw-bar__star { color: var(--accent); }
  .potw-bar__label { font-weight: 700; }
  .potw-bar__name { font-weight: 600; }
  .potw-bar__arrow { transition: transform 0.15s ease; }
  .potw-bar:hover { background: var(--primary-600); }
  .potw-bar:hover .potw-bar__arrow { transform: translateX(3px); }
  @media (max-width: 480px) {
    .potw-bar__label { display: none; }
  }
</style>
