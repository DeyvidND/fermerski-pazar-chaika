---
import type { Farmer } from '../lib/types';
import { coverCropStyle } from '../lib/cover-crop';
import { cfImage, cfSrcset } from '../lib/img';

interface Props {
  farmer: Farmer;
  productCount: number;
  categoryCount: number;
}
const { farmer: f, productCount, categoryCount } = Astro.props;
const eyebrow = [f.role, f.since ? 'от ' + f.since : null].filter(Boolean).join(' · ');
---
<article class="card farmer-card">
  <a href={`/farmer/${f.id}`} class="ph farmer-card__photo">
    {f.imageUrl ? (
      <img src={cfImage(f.imageUrl, 800)} srcset={cfSrcset(f.imageUrl, [400, 800])}
           sizes="(max-width:700px) 100vw, 360px" alt={f.name} loading="lazy" decoding="async"
           style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;${coverCropStyle(f.coverCrop)}`} />
    ) : (
      <span class="ph__label">{f.name}</span>
    )}
  </a>
  <div class="farmer-card__body">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h3 class="farmer-card__name">{f.name}</h3>
    {f.role && <div class="farmer-card__person">{f.role}</div>}
    {f.bio && <p class="farmer-card__blurb">{f.bio}</p>}
    <div class="farmer-card__foot">
      <span class="farmer-card__count">{productCount} продукта · {categoryCount} категории</span>
      <a href={`/farmer/${f.id}`} class="btn btn--primary btn--sm">Виж продуктите →</a>
    </div>
  </div>
</article>
