---
import { money } from '../lib/money';
import { coverCropStyle } from '../lib/cover-crop';
import type { Product } from '../lib/types';

interface Props {
  potw: Product;
  note?: string | null;
}
const { potw, note } = Astro.props;
const href = potw.slug ? `/product/${potw.slug}` : '/shop';
// Cover photo straight off the product — legacy `imageUrl` or the gallery's
// first image. The farmer never re-uploads it for the highlight.
const cover = potw.imageUrl ?? potw.images?.[0] ?? null;
const hasImg = !!cover;
---
<!--
  «Продукт на седмицата» full section. Its own layout — deliberately NOT the
  hero's `.hero-grid`, whose theme overrides absolutely-position the last child
  as a full-bleed background (great for the hero photo, broken here). With an
  image: photo left, copy right. Without one: a clean centred text card — no
  empty placeholder box.
-->
<section class={`section potw ${hasImg ? 'potw--media' : 'potw--text'}`}>
  <div class="wrap potw__inner">
    {hasImg && (
      <a href={href} class="potw__media" aria-label={potw.name}>
        <img src={cover} alt={potw.name} loading="lazy" style={coverCropStyle(potw.coverCrop)} />
      </a>
    )}
    <div class="potw__body">
      <span class="eyebrow">★ Продукт на седмицата</span>
      <h2 class="potw__name">{potw.name}</h2>
      {note && <p class="lead potw__note">{note}</p>}
      <div class="potw__price">{money(potw.priceStotinki)}</div>
      <a href={href} class="btn btn--primary btn--lg potw__cta">Виж продукта</a>
    </div>
  </div>
</section>

<style>
  .potw { background: var(--surface-2); }
  .potw__inner {
    display: grid;
    gap: clamp(24px, 4vw, 52px);
    align-items: center;
  }
  /* With a photo: image left, copy right. */
  .potw--media .potw__inner {
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  }
  /* No photo: a single centred column — no empty placeholder. */
  .potw--text .potw__inner {
    grid-template-columns: 1fr;
    max-width: 720px;
    text-align: center;
    justify-items: center;
  }
  .potw__media {
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
  }
  .potw__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .potw__name {
    font-size: clamp(26px, 3.4vw, 40px);
    line-height: 1.1;
    margin-top: 10px;
  }
  .potw__note { margin-top: 14px; max-width: 46ch; }
  .potw--text .potw__note { margin-inline: auto; }
  .potw__price {
    font-size: clamp(24px, 3vw, 30px);
    font-weight: 700;
    color: var(--primary);
    margin-top: 16px;
  }
  .potw__cta { margin-top: 22px; }

  @media (max-width: 760px) {
    .potw--media .potw__inner {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }
    .potw--media .potw__media { width: 100%; max-width: 460px; }
    .potw--media .potw__note { margin-inline: auto; }
  }
</style>
