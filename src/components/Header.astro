---
import Icon from './Icon.astro';
import CopySlot from './CopySlot.astro';
import { navLinks, isActive } from '../lib/nav';
import { BRAND_TAG, telHref, contactPhone, safeHref } from '../lib/site';
import type { Storefront } from '../lib/types';

interface Props { storefront: Storefront }
const { storefront } = Astro.props;
const links = navLinks(storefront.multiFarmer);
const path = Astro.url.pathname;
const phone = contactPhone(storefront);
// The tenant's configured website icon (settings.brand.favicon). When set, it
// replaces the static berry mark in the header/drawer brand; else fall back.
const brandIcon = storefront.faviconUrl ? safeHref(storefront.faviconUrl) : storefront.faviconUrl;
---
<header class="site-header">
  <div class="wrap">
    <nav class="nav">
      <a href="/" class="brand">
        <span class:list={["brand__mark", brandIcon && "brand__mark--img"]}>
          {brandIcon ? <img src={brandIcon} alt={storefront.name} /> : <Icon name="berry" />}
        </span>
        <span>
          <span class="brand__name"><CopySlot slot="site.brand.name" copy={storefront.copy} fallback={storefront.name} /></span>
          <span class="brand__tag" style="display:block"><CopySlot slot="site.brand.tag" copy={storefront.copy} fallback={BRAND_TAG} /></span>
        </span>
      </a>
      <div class="nav__links">
        {links.map((l) => (
          <a href={l.href} class={isActive(path, l.href) ? 'active' : ''}>{l.label}</a>
        ))}
      </div>
      <div class="nav__actions">
        <a href="/cart" class="icon-btn" aria-label="Количка">
          <Icon name="cart" /><span class="cart-count is-zero">0</span>
        </a>
        <button class="icon-btn hamburger" id="hamburger" aria-label="Меню"><Icon name="menu" /></button>
      </div>
    </nav>
  </div>
</header>

<!-- mobile drawer -->
<div class="drawer-backdrop" id="drawerBackdrop"></div>
<aside class="drawer" id="drawer" aria-hidden="true">
  <div class="drawer__head">
    <span class="brand"><span class:list={["brand__mark", brandIcon && "brand__mark--img"]}>
        {brandIcon ? <img src={brandIcon} alt={storefront.name} /> : <Icon name="berry" />}
      </span>
      <span class="brand__name"><CopySlot slot="site.brand.name" copy={storefront.copy} fallback={storefront.name} /></span></span>
    <button class="icon-btn" id="drawerClose" aria-label="Затвори"><Icon name="close" /></button>
  </div>
  {links.map((l) => (
    <a href={l.href} class={isActive(path, l.href) ? 'active' : ''}>{l.label}</a>
  ))}
  <a href="/cart" style="display:flex;align-items:center;gap:10px"><Icon name="cart" /> Количка</a>
  {phone && (
    <div style="margin-top:auto;padding-top:18px;color:var(--muted);font-size:14px">
      <a href={telHref(phone)}>{phone}</a>
    </div>
  )}
</aside>
