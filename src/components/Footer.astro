---
import Icon from './Icon.astro';
import { telHref, resolveSocials, contactPhone, contactEmail, customFields, contactValueHref, contactAddress, contactHours, contactTagline } from '../lib/site';
import { ADMIN_LOGIN_URL } from '../lib/config';
import type { Storefront } from '../lib/types';

interface Props { storefront: Storefront }
const { storefront } = Astro.props;
const phone = contactPhone(storefront);
const email = contactEmail(storefront);
const extra = customFields(storefront);
const socials = resolveSocials(storefront);
const year = 2026;
---
<footer class="site-footer">
  <div class="wrap footer-grid">
    <div>
      <span class="brand">
        <span class="brand__mark"><Icon name="berry" /></span>
        <span class="brand__name">{storefront.name}</span>
      </span>
      <p style="margin-top:14px;opacity:.85;max-width:32ch;font-size:15px">
        {contactTagline(storefront)}
      </p>
      <div class="socials">
        {socials.map((s) => (
          <a href={s.href} aria-label={s.label} target="_blank" rel="noopener"><Icon name={s.icon} /></a>
        ))}
      </div>
    </div>
    <div>
      <h4>Пазарувай</h4>
      <div class="footer-links">
        <a href="/shop">Магазин</a>
        {storefront.multiFarmer && <a href="/farmers">Фермери</a>}
        <a href="/orders">Поръчки</a>
        <a href="/cart">Количка</a>
      </div>
    </div>
    <div>
      <h4>Информация</h4>
      <div class="footer-links">
        <a href="/about">За нас</a>
        <a href="/reviews">Отзиви</a>
        <a href="/faq">Чести въпроси</a>
        <a href="/contact">Контакти</a>
      </div>
    </div>
    <div>
      <h4>Пазар &amp; контакти</h4>
      <div class="footer-contact">
        {contactAddress(storefront)}<br>
        <b style="color:#fff">{contactHours(storefront)}</b><br>
        {phone && <Fragment><a href={telHref(phone)}>{phone}</a><br></Fragment>}
        {email && <Fragment><a href={`mailto:${email}`}>{email}</a><br></Fragment>}
        {extra.map((f) => {
          const href = contactValueHref(f.value);
          return (
            <Fragment>
              {f.label && <span style="opacity:.75">{f.label}: </span>}
              {href ? <a href={href}>{f.value}</a> : <span>{f.value}</span>}<br>
            </Fragment>
          );
        })}
      </div>
    </div>
  </div>
  <div class="wrap footer-bottom">
    <span>© {year} {storefront.name} · Фермерски пазар Чайка, Варна.</span>
    <span style="display:flex;gap:18px;align-items:center;flex-wrap:wrap">
      <a href={ADMIN_LOGIN_URL} rel="nofollow">Вход за стопани</a>
      <span>Всички права запазени.</span>
    </span>
  </div>
</footer>
