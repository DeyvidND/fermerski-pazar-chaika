---
/**
 * «Налично сега» — home-page section that surfaces products with an active
 * availability window from the FarmFlow API.
 *
 * Props:
 *   title      — section heading (the admin-configured title; caller passes
 *                the falsy-coerced fallback „Налично сега" already).
 *   products   — full catalog product list (to look up by productId).
 *   farmers    — full farmer list (for multiFarmer grouping).
 *   windows    — active availability windows for today (may be empty → caller
 *                should not even mount this component, but we guard anyway).
 *   multiFarmer — whether to group items by farmer (mirrors home-page logic).
 */
import ProductCard from './ProductCard.astro';
import type { Product, Farmer, PublicAvailabilityWindow } from '../lib/types';

interface Props {
  title: string;
  products: Product[];
  farmers: Farmer[];
  windows: PublicAvailabilityWindow[];
  multiFarmer: boolean;
}

const { title, products, farmers, windows, multiFarmer } = Astro.props;

// Build a map from productId → window so we can overlay remaining/sold-out info.
const windowByProductId = new Map<string, PublicAvailabilityWindow>();
for (const w of windows) {
  // If a product has multiple windows (shouldn't happen for today) take the
  // first-encountered (server returns them ordered by startsAt).
  if (!windowByProductId.has(w.productId)) {
    windowByProductId.set(w.productId, w);
  }
}

// Build a map from productId → Product for fast lookup.
const productById = new Map<string, Product>(products.map((p) => [p.id, p]));

// Active window items: only windows whose product exists in the catalog.
interface AvailItem {
  product: Product;
  window: PublicAvailabilityWindow;
}

const items: AvailItem[] = [];
for (const w of windows) {
  const p = productById.get(w.productId);
  if (p && p.isActive !== false) {
    items.push({ product: p, window: w });
  }
}

// Guard: nothing to show.
if (items.length === 0) {
  // Render nothing — Astro returns an empty fragment.
  return;
}

// Farmer grouping (multiFarmer mode).
interface FarmerGroup {
  farmer: Farmer | null; // null = "no farmer assigned"
  items: AvailItem[];
}

let groups: FarmerGroup[] = [];
if (multiFarmer) {
  const farmerById = new Map<string, Farmer>(farmers.map((f) => [f.id, f]));
  const byFarmer = new Map<string | null, AvailItem[]>();
  for (const item of items) {
    const fid = item.product.farmerId ?? null;
    if (!byFarmer.has(fid)) byFarmer.set(fid, []);
    byFarmer.get(fid)!.push(item);
  }
  for (const [fid, farmerItems] of byFarmer) {
    groups.push({ farmer: fid ? (farmerById.get(fid) ?? null) : null, items: farmerItems });
  }
} else {
  groups = [{ farmer: null, items }];
}
---

<section class="section avail-section">
  <div class="wrap">
    <div class="section-head" style="margin-bottom:28px">
      <span class="eyebrow">Днес · ограничено количество</span>
      <h2 style="margin-top:8px">{title}</h2>
    </div>

    {groups.map(({ farmer, items: groupItems }) => (
      <div class="avail-group">
        {multiFarmer && farmer && (
          <h3 class="avail-farmer-heading">{farmer.name}</h3>
        )}
        <div class="grid grid--4">
          {groupItems.map(({ product, window: w }) => {
            const soldOut = w.remaining === 0;
            return (
              <div class={`avail-card-wrap${soldOut ? ' avail-card-wrap--sold-out' : ''}`}>
                {/* Reuse the existing ProductCard unchanged — add overlay badges on top */}
                <ProductCard product={product} />
                {/* Remaining badge or sold-out overlay */}
                {soldOut ? (
                  <div class="avail-badge avail-badge--sold-out" aria-label="Изчерпан">
                    изчерпан
                  </div>
                ) : (
                  <div class="avail-badge avail-badge--remaining">
                    остават {w.remaining}
                  </div>
                )}
                {/* Sold-out click shield: sits over the card's add-to-cart button area
                    so the browser-native disabled isn't needed on the inner button.
                    We intercept pointer events on the whole card when sold out. */}
                {soldOut && <div class="avail-sold-out-shield" aria-hidden="true" />}
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .avail-section {
    background: var(--surface-2);
  }

  .avail-group + .avail-group {
    margin-top: 36px;
  }

  .avail-farmer-heading {
    font-size: clamp(17px, 2vw, 22px);
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text-1);
  }

  /* Wrapper that positions overlay badges relative to the card */
  .avail-card-wrap {
    position: relative;
  }

  /* Remaining stock badge — green pill in the bottom-left of the card image */
  .avail-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 3;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.4;
    pointer-events: none;
  }

  .avail-badge--remaining {
    background: var(--primary, #2d6a4f);
    color: #fff;
  }

  .avail-badge--sold-out {
    background: rgba(0, 0, 0, 0.65);
    color: #fff;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-size: 11px;
  }

  /* Sold-out: dim the card and block all interactions */
  .avail-card-wrap--sold-out {
    opacity: 0.55;
    pointer-events: none;
    user-select: none;
  }

  /* Full-card click shield (belt-and-suspenders for sold-out; the wrapper's
     pointer-events:none already covers most cases, but this blocks any
     browser that passes events through to children) */
  .avail-sold-out-shield {
    position: absolute;
    inset: 0;
    z-index: 4;
    cursor: not-allowed;
    pointer-events: all; /* re-enable so it catches clicks */
  }
</style>
