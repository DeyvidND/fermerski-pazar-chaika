---
import Icon from './Icon.astro';
import { money } from '../lib/money';
import { coverCropStyle } from '../lib/cover-crop';
import { cfImage, cfSrcset } from '../lib/img';
import type { Product } from '../lib/types';

interface Props {
  product: Product;
  stepper?: boolean;
  farmerName?: string | null;
  cat?: string; // grouping id, used by the catalog filter tabs
  remaining?: number | null; // active availability window remaining stock (undefined = no window)
}
const { product: p, stepper = false, farmerName = null, cat = '', remaining = null } = Astro.props;
const href = p.slug ? `/product/${p.slug}` : '/shop';
const priceLv = (p.priceStotinki / 100).toFixed(2);
const tag = p.featured ? '★ Популярен' : p.compareAtPriceStotinki ? 'Промо' : null;
const metaBits = [p.weight, farmerName].filter(Boolean).join(' · ');
const photoCount = p.images?.length ?? (p.imageUrl ? 1 : 0);
const shapeAspect = p.coverCrop?.shape === 'square' ? '1/1' : p.coverCrop?.shape === 'tall' ? '4/5' : null;

// Availability badge state
const hasWindow = remaining !== null && remaining !== undefined;
const soldOut = hasWindow && remaining === 0;
---
<article class={`card product${soldOut ? ' product--sold-out' : ''}`} data-product data-cat={cat}
  style={soldOut ? 'opacity:0.72' : undefined}>
  <a href={href} class="ph" style={shapeAspect ? `aspect-ratio:${shapeAspect}` : undefined}>
    {tag && <span class="tag" style="position:absolute;top:12px;left:12px;z-index:2">{tag}</span>}
    {photoCount > 1 && (
      <span class="photo-count" style="position:absolute;bottom:10px;right:10px;z-index:2;display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:999px;background:rgba(0,0,0,.55);color:#fff;font-size:12px;font-weight:700">
        <Icon name="camera" /> {photoCount}
      </span>
    )}
    {p.imageUrl ? (
      <img src={cfImage(p.imageUrl, 720)} srcset={cfSrcset(p.imageUrl, [360, 720])}
           sizes="(max-width:700px) 50vw, 320px" alt={p.name} loading="lazy" decoding="async"
           style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;${coverCropStyle(p.coverCrop)}`} />
    ) : (
      <span class="ph__label">{p.name}</span>
    )}
    {/* Stock badge — shown only when there is an active availability window */}
    {hasWindow && (
      soldOut ? (
        <span class="stock-badge stock-badge--sold-out" aria-label="Изчерпан">изчерпан</span>
      ) : (
        <span class="stock-badge stock-badge--remaining">{remaining} в наличност</span>
      )
    )}
  </a>
  <div class="product__body">
    <a href={href}><h3 class="product__name">{p.name}</h3></a>
    {metaBits && <div class="product__meta">{metaBits}</div>}
    <div class="product__price">
      {money(p.priceStotinki)}
      {p.compareAtPriceStotinki && (
        <span class="muted" style="font-size:14px;font-weight:500;text-decoration:line-through;margin-left:8px">
          {money(p.compareAtPriceStotinki)}
        </span>
      )}
    </div>
    <div class="product__foot">
      {stepper && !soldOut && (
        <div class="stepper" aria-label="Количество">
          <button data-dir="down" aria-label="по-малко">−</button>
          <input type="number" value="1" min="1" inputmode="numeric" />
          <button data-dir="up" aria-label="повече">+</button>
        </div>
      )}
      <button class="btn btn--primary btn--sm btn--full" data-add-cart
        data-id={p.id} data-name={p.name} data-price={priceLv} data-weight={p.weight || ''}
        disabled={soldOut || undefined}
        style={soldOut ? 'opacity:0.5;pointer-events:none;cursor:not-allowed' : undefined}>
        <Icon name="cart" /> {soldOut ? 'Изчерпан' : 'Добави'}
      </button>
    </div>
  </div>
</article>

<style>
  /* Stock availability badge — overlays the product image */
  .stock-badge {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 3;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.4;
    pointer-events: none;
  }

  .stock-badge--remaining {
    background: var(--color-primary, #4C8A54);
    color: #fff;
  }

  .stock-badge--sold-out {
    background: #c0392b;
    color: #fff;
  }
</style>
