---
import Icon from './Icon.astro';
import { money, moneyEurOnly } from '../lib/money';
import { coverCropStyle } from '../lib/cover-crop';
import { cfImage, cfSrcset } from '../lib/img';
import { priceDisplay, discountPercent, hasVariants, allVariantsSoldOut } from '../lib/pricing';
import type { Product } from '../lib/types';

interface Props {
  product: Product;
  stepper?: boolean;
  farmerName?: string | null;
  farmerCourierReady?: boolean;
  /** Farmer id → links the card's farmer row to their micro-store. Omit on the
   *  farmer's own page (already there, so no link/avatar needed). */
  farmerId?: string | null;
  /** Collision-safe `/farmer/<slug>` slug (from `farmerSlugMap`) for the link
   *  built from `farmerId`. Falls back to the raw id when omitted. */
  farmerSlug?: string | null;
  /** Farmer photo for the small round avatar. Absent → initials fallback. */
  farmerImage?: string | null;
  cat?: string; // grouping id, used by the catalog filter tabs
  remaining?: number | null; // active availability window remaining stock (undefined = no window)
  bestSeller?: boolean; // member of the „Най-продавани" set → shown under that chip
}
const {
  product: p,
  stepper = false,
  farmerName = null,
  farmerCourierReady = false,
  farmerId = null,
  farmerSlug = null,
  farmerImage = null,
  cat = '',
  remaining = null,
  bestSeller = false,
} = Astro.props;

// Courier delivery badge logic:
// - green "Доставка с куриер" when farmer has carrier AND product not blocked
// - amber "Само на място" when farmer has carrier but product is blocked
// - nothing when farmer has no carrier (courier not applicable)
const courierAvailable = farmerCourierReady && !(p.courierDisabled ?? false);
const pickupOnly = farmerCourierReady && (p.courierDisabled ?? false);
const href = p.slug ? `/product/${p.slug}` : '/shop';
const hasV = hasVariants(p);
const pd = priceDisplay(p);
const discount = discountPercent(pd);
const priceLv = (pd.headlineStotinki / 100).toFixed(2);
const tag = p.featured ? '★ Популярен' : pd.compareStotinki != null ? 'Промо' : null;
// Ready-made bundle (task #1): a готова кошница sold as one SKU.
const isBundle = (p.bundleProducts?.length ?? 0) > 0 || p.category === 'bundle';
// Farmer row: links to the micro-store when an id is given (omitted on the
// farmer's own page, where the link would be redundant). No image → initials.
// `farmerSlug` (collision-safe, from farmerSlugMap) is preferred; falls back
// to the raw id so an un-migrated caller still links somewhere valid.
const farmerHref = farmerId ? `/farmer/${farmerSlug || farmerId}` : null;
const farmerInitials = farmerName
  ? farmerName.trim().split(/\s+/).map((w) => w[0]).filter(Boolean).slice(0, 2).join('').toLocaleUpperCase('bg')
  : '';
const photoCount = p.images?.length ?? (p.imageUrl ? 1 : 0);
const shapeAspect = p.coverCrop?.shape === 'square' ? '1/1' : p.coverCrop?.shape === 'tall' ? '4/5' : null;

// Availability badge state. A varianted product is sold out only when every
// variant is sold out; the legacy per-product window applies to plain products.
const hasWindow = remaining !== null && remaining !== undefined;
const soldOut = (hasWindow && remaining === 0) || allVariantsSoldOut(p);
---
<article class={`card product${soldOut ? ' product--sold-out' : ''}`} data-product data-cat={cat} data-bestseller={bestSeller ? '1' : undefined}
  data-courier={courierAvailable ? '1' : undefined}
  data-farmer={farmerId ?? undefined}
  data-name={[p.name, farmerName].filter(Boolean).join(' ').toLocaleLowerCase('bg')}
  style={soldOut ? 'opacity:0.72' : undefined}>
  <a href={href} class="ph" style={shapeAspect ? `aspect-ratio:${shapeAspect}` : undefined}>
    {tag && <span class="tag" style="position:absolute;top:12px;left:12px;z-index:2">{tag}</span>}
    {isBundle && <span class="tag" style="position:absolute;top:12px;left:12px;z-index:2;transform:translateY(28px);background:#4a7c3a">🧺 Пакет</span>}
    {bestSeller && <span class="hit-badge" style="position:absolute;top:12px;right:12px;z-index:2">Хит</span>}
    {photoCount > 1 && (
      <span class="photo-count" style="position:absolute;bottom:10px;right:10px;z-index:2;display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:999px;background:rgba(0,0,0,.55);color:#fff;font-size:12px;font-weight:700">
        <Icon name="camera" /> {photoCount}
      </span>
    )}
    {p.imageUrl ? (
      <img src={cfImage(p.imageUrl, 720)} srcset={cfSrcset(p.imageUrl, [360, 720])}
           sizes="(max-width:700px) 50vw, 320px" alt={p.name} loading="lazy" decoding="async"
           style={`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;${coverCropStyle(p.coverCrop)}`} />
    ) : (
      <span class="ph__label">{p.name}</span>
    )}
    {/* Stock badge — shown only when there is an active availability window */}
    {hasWindow && (
      soldOut ? (
        <span class="stock-badge stock-badge--sold-out" aria-label="Изчерпан">изчерпан</span>
      ) : (
        <span class="stock-badge stock-badge--remaining">{remaining} в наличност</span>
      )
    )}
  </a>
  <div class="product__body">
    <a href={href}><h3 class="product__name">{p.name}</h3></a>
    {p.weight && <div class="product__meta">{p.weight}</div>}
    {farmerName?.trim() && (
      farmerHref ? (
        <a href={farmerHref} class="product__farmer">
          <span class="avatar">
            {farmerImage ? (
              <img src={cfImage(farmerImage, 96)} alt="" loading="lazy" decoding="async" />
            ) : (
              <span class="avatar__initials">{farmerInitials}</span>
            )}
          </span>
          <span class="product__farmer-name">{farmerName}</span>
        </a>
      ) : (
        <div class="product__farmer product__farmer--plain">{farmerName}</div>
      )
    )}
    <div class="product__price">
      {pd.fromPrefix && <span class="muted" style="font-weight:500;font-size:14px">от </span>}
      <Fragment set:html={money(pd.headlineStotinki)} />
      {pd.compareStotinki != null && (
        <span class="muted" style="font-size:14px;font-weight:500;text-decoration:line-through;margin-left:8px">
          {moneyEurOnly(pd.compareStotinki)}
        </span>
      )}
      {discount != null && (
        <span style="font-size:12px;font-weight:700;color:#fff;background:#c0392b;border-radius:999px;padding:2px 8px;margin-left:6px">
          -{discount}%
        </span>
      )}
    </div>
    {courierAvailable && (
      <div class="courier-on" title="Може да се изпрати с куриер (Еконт или Спиди)">
        📦 Доставка с куриер
      </div>
    )}
    {pickupOnly && (
      <div class="courier-off" title="Само вземане от място или местна доставка — не се изпраща с куриер">
        Само на място
      </div>
    )}
    <div class="product__foot">
      {stepper && !soldOut && !hasV && (
        <div class="stepper" aria-label="Количество">
          <button data-dir="down" aria-label="по-малко">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/></svg>
          </button>
          <input type="number" value="1" min="1" inputmode="numeric" />
          <button data-dir="up" aria-label="повече">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          </button>
        </div>
      )}
      {hasV ? (
        <a href={href} class="btn btn--primary btn--sm btn--full"
          style={soldOut ? 'opacity:0.5' : undefined}>
          <Icon name="cart" /> {soldOut ? 'Изчерпан' : 'Избери вариант'}
        </a>
      ) : (
        <button class="btn btn--primary btn--sm btn--full" data-add-cart
          data-id={p.id} data-name={p.name} data-price={priceLv} data-weight={p.weight || ''}
          data-farmer-id={farmerId ?? undefined} data-farmer-name={farmerName ?? undefined}
          data-requires-companion={p.requiresCompanion ? '1' : undefined}
          data-companion-min={p.companionMinPriceStotinki ?? undefined}
          disabled={soldOut || undefined}
          style={soldOut ? 'opacity:0.5;pointer-events:none;cursor:not-allowed' : undefined}>
          <Icon name="cart" /> {soldOut ? 'Изчерпан' : 'Добави'}
        </button>
      )}
    </div>
    {p.requiresCompanion && !soldOut && !hasV && (
      <p class="companion-hint" data-companion-hint>
        <span aria-hidden="true">🧺</span>
        {p.companionMinPriceStotinki
          ? `Промо цена — добавя се към поръчка с други продукти за поне ${moneyEurOnly(p.companionMinPriceStotinki)}`
          : 'Промо цена — добавя се заедно с още поне един продукт'}
      </p>
    )}
  </div>
</article>

<style>
  /* Stock availability badge — overlays the product image */
  .stock-badge {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 3;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.4;
    pointer-events: none;
  }

  .stock-badge--remaining {
    /* Dedicated darker green — NOT --color-primary (that's ~3.6:1 with white text
       at this weight/size, fails WCAG AA). Kept local to this badge only. */
    background: #3F7D43;
    color: #fff;
  }

  .stock-badge--sold-out {
    background: #c0392b;
    color: #fff;
  }

  /* Courier availability badges */
  .courier-on {
    display: inline-flex;
    align-self: flex-start;
    margin-top: 4px;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: #e8f5e9;
    color: #2e7d32;
  }

  .courier-off {
    display: inline-flex;
    align-self: flex-start;
    margin-top: 4px;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: #fdf1e3;
    color: #9a5b13;
  }

  /* „Хит" badge — overlays the image, mirrors the .tag promo pill on the
     opposite corner. Amber is fixed (not theme-accent) so it reads the same
     „best-seller" signal on every theme, same reasoning as the stock badges. */
  .hit-badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 11px;
    border-radius: var(--chip-radius, 999px);
    background: #E8A33D;
    color: #2a2110;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .02em;
  }

  /* Farmer row — small avatar (photo or initials) + name, linking to the
     farmer's micro-store. Kept to one line so 2-up mobile cards never overflow. */
  .product__farmer {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-top: 4px;
    min-width: 0;
    text-decoration: none;
  }
  a.product__farmer:hover .product__farmer-name { text-decoration: underline; }
  .product__farmer .avatar {
    flex: none;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    overflow: hidden;
    display: grid;
    place-items: center;
    background: var(--color-primary, #4C8A54);
    color: #fff;
  }
  .product__farmer .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product__farmer .avatar__initials {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .02em;
  }
  .product__farmer-name {
    font-size: 13px;
    font-weight: 600;
    /* --ink (not the brand green) — the green fails AA at 13px (~3.6:1); the
       avatar + hover underline already signal it's a link. */
    color: var(--ink);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .product__farmer--plain {
    font-size: 13px;
    color: var(--muted);
  }

  /* Loss-leader companion hint — explains WHY the add button is gated and how to
     unlock it (the button itself carries the live shortfall). Warm cream tint =
     „special price", not an error; full-radius background, no accent stripe.
     Toggled by refreshCompanionLocks() — hidden once the basket qualifies. */
  .companion-hint {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    margin: 8px 0 0;
    padding: 7px 10px;
    border-radius: 10px;
    background: #fbf1e2;
    color: #7a4f16;
    font-size: 12px;
    line-height: 1.4;
    font-weight: 600;
  }
  .companion-hint[hidden] { display: none; }
</style>
