# FarmFlow backend base URL (no trailing slash). Used both server-side (SSR
# data fetch) and client-side (cart checkout / forms) — hence the PUBLIC_ prefix
# so Astro exposes it to the browser bundle too.
PUBLIC_API_BASE=http://localhost:3000

# Which farm storefront to render. Maps to tenants.slug in the backend.
PUBLIC_TENANT_SLUG=ferma-petrovi

# FarmFlow admin panel (the @farmflow/web app). The storefront footer links to
# <PUBLIC_ADMIN_URL>/login so the farm owner can sign in and manage content.
PUBLIC_ADMIN_URL=http://localhost:3005
